---
export const prerender = true;
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Corpus — The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
</head>
<body>
  <SiteNav />

  <div class="corpus-page">
    <div class="container">
      <div class="corpus-head">
        <h1 class="corpus-title">Corpus</h1>
        <div class="corpus-actions">
          <button id="selectToggle" class="corpus-select-btn">Select to compare</button>
          <a href="/catalog" class="corpus-action-link">+ Catalog new object</a>
        </div>
        <p class="corpus-sub">All cataloged objects. Click any object to view its fingerprint and run an analysis.</p>
      </div>

      <!-- Filter bar -->
      <div id="filterBar" class="filter-bar" style="display:none">
        <button id="conflictFilter" class="filter-btn filter-btn-conflict">
          ⚠ Sources disagree
          <span id="conflictCount" class="filter-count"></span>
        </button>
        <button id="referenceFilter" class="filter-btn filter-btn-reference" style="display:none">
          ◆ Reference corpus
          <span id="referenceCount" class="filter-count"></span>
        </button>
        <button id="clearFilter" class="filter-clear" style="display:none">Show all</button>
      </div>

      <div id="loading" class="corpus-loading">Loading objects…</div>
      <div id="empty" class="corpus-empty" style="display:none">
        No objects cataloged yet. <a href="/catalog">Catalog the first one →</a>
      </div>
      <div id="grid" class="object-grid" style="display:none"></div>

      <!-- Sticky selection bar -->
      <div id="selectionBar" class="selection-bar" style="display:none">
        <span id="selCount" class="sel-count">0 selected</span>
        <div class="sel-actions">
          <button id="clearSelBtn" class="sel-clear">Clear</button>
          <a id="compareLink" href="/compare" class="sel-compare">Compare →</a>
        </div>
      </div>
    </div>
  </div>

  <SiteFooter />

<script>
const esc = s => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

// ── State ───────────────────────────────────────────────────────────────────
let allObjects = [];
let selectMode = false;
const selectedIds = new Set();
let activeFilter = 'none'; // 'none' | 'conflict' | 'reference'

// ── DOM refs ─────────────────────────────────────────────────────────────────
const loading      = document.getElementById('loading');
const empty        = document.getElementById('empty');
const grid         = document.getElementById('grid');
const selBar       = document.getElementById('selectionBar');
const selCount     = document.getElementById('selCount');
const compareLink  = document.getElementById('compareLink');
const clearSelBtn  = document.getElementById('clearSelBtn');
const selectToggle = document.getElementById('selectToggle');

// ── Toggle select mode ───────────────────────────────────────────────────────
selectToggle.addEventListener('click', () => {
  selectMode = !selectMode;
  if (!selectMode) { selectedIds.clear(); updateBar(); }
  selectToggle.textContent = selectMode ? '✕ Cancel selection' : 'Select to compare';
  selectToggle.classList.toggle('select-active', selectMode);
  renderGrid();
});

clearSelBtn.addEventListener('click', () => {
  selectedIds.clear();
  updateBar();
  renderGrid();
});

function updateBar() {
  const n = selectedIds.size;
  selBar.style.display = n > 0 ? '' : 'none';
  selCount.textContent = `${n} object${n !== 1 ? 's' : ''} selected`;
  compareLink.href = `/compare?ids=${[...selectedIds].join(',')}`;
}

// ── Render ────────────────────────────────────────────────────────────────────
function renderGrid() {
  if (!allObjects.length) return;
  let displayObjects = allObjects;
  if (activeFilter === 'conflict')   displayObjects = allObjects.filter(o => o.claim_conflict);
  else if (activeFilter === 'reference') displayObjects = allObjects.filter(o => o.is_reference);
  if (displayObjects.length === 0) {
    grid.innerHTML = '<p class="corpus-empty">No objects match this filter.</p>';
    return;
  }
  grid.innerHTML = displayObjects.map(obj => {
    const imgKey  = obj.image_analysis_key?.split(',')[0]?.trim();
    const imgSrc  = imgKey ? `/api/image/${imgKey}` : null;
    const culture = esc(obj.attribution_culture ?? '—');
    const displayId = esc(obj.catalog_number ?? `#${obj.id}`);
    const hasFingerprint = !!obj.fingerprinted_at;
    const date = obj.fingerprinted_at
      ? new Date(obj.fingerprinted_at).toLocaleString('en-US', { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit', timeZone: 'America/Los_Angeles', timeZoneName: 'short' })
      : '';
    const isSelected = selectedIds.has(obj.id);
    const refBadge = obj.is_reference ? `<span class="card-ref">REF</span>` : '';

    if (selectMode) {
      return `
        <button type="button" class="object-card card-selectable ${isSelected ? 'card-checked' : ''}" data-id="${obj.id}">
          <div class="card-check-overlay">${isSelected ? '✓' : ''}</div>
          ${imgSrc
            ? `<div class="card-image"><img src="${imgSrc}" alt="${displayId}" loading="lazy" /></div>`
            : `<div class="card-no-image">No image</div>`}
          <div class="card-body">
            <p class="card-display-id">${displayId}</p>
            <p class="card-culture">${culture}</p>
            <div class="card-meta">
              <span class="${hasFingerprint ? 'card-fp-yes' : 'card-fp-no'}">
                ${hasFingerprint ? '● Fingerprinted' : '○ No fingerprint'}
              </span>
              ${refBadge}
            </div>
          </div>
        </button>`;
    }

    return `
      <a href="/corpus/${obj.id}" class="object-card">
        ${imgSrc
          ? `<div class="card-image"><img src="${imgSrc}" alt="${displayId}" loading="lazy" /></div>`
          : `<div class="card-no-image">No image</div>`}
        <div class="card-body">
          <p class="card-display-id">${displayId}</p>
          <p class="card-culture">${culture}</p>
          <div class="card-meta">
            <span class="${hasFingerprint ? 'card-fp-yes' : 'card-fp-no'}">
              ${hasFingerprint ? '● Fingerprinted' : '○ No fingerprint'}
            </span>
            <div class="card-meta-right">
              ${obj.claim_conflict ? '<span class="card-conflict">⚠ disagree</span>' : `<span class="card-date">${date}</span>`}
              ${refBadge}
            </div>
          </div>
        </div>
      </a>`;
  }).join('');

  // Selection click handlers
  if (selectMode) {
    grid.querySelectorAll('.card-selectable').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = Number(btn.dataset.id);
        if (selectedIds.has(id)) selectedIds.delete(id);
        else selectedIds.add(id);
        updateBar();
        renderGrid();
      });
    });
  }
}

// ── Filters ────────────────────────────────────────────────────────────────────

const filterBar       = document.getElementById('filterBar');
const conflictFilter  = document.getElementById('conflictFilter');
const conflictCount   = document.getElementById('conflictCount');
const referenceFilter = document.getElementById('referenceFilter');
const referenceCount  = document.getElementById('referenceCount');
const clearFilter     = document.getElementById('clearFilter');

function setFilter(name) {
  activeFilter = name;
  conflictFilter?.classList.toggle('filter-active', name === 'conflict');
  referenceFilter?.classList.toggle('filter-active', name === 'reference');
  clearFilter.style.display = name !== 'none' ? '' : 'none';
  renderGrid();
}

conflictFilter?.addEventListener('click', () => setFilter(activeFilter === 'conflict' ? 'none' : 'conflict'));
referenceFilter?.addEventListener('click', () => setFilter(activeFilter === 'reference' ? 'none' : 'reference'));
clearFilter?.addEventListener('click', () => setFilter('none'));

// ── Load ──────────────────────────────────────────────────────────────────────
async function load() {
  try {
    const res = await fetch('/api/objects');
    if (!res.ok) throw new Error(`${res.status}`);
    allObjects = await res.json();
    loading.style.display = 'none';
    if (!allObjects.length) { empty.style.display = ''; return; }
    grid.style.display = '';

    const conflictObjs  = allObjects.filter(o => o.claim_conflict);
    const referenceObjs = allObjects.filter(o => o.is_reference);
    const showBar = conflictObjs.length > 0 || referenceObjs.length > 0;
    if (showBar) filterBar.style.display = '';
    if (conflictObjs.length > 0) conflictCount.textContent = `(${conflictObjs.length})`;
    if (referenceObjs.length > 0) {
      referenceFilter.style.display = '';
      referenceCount.textContent = `(${referenceObjs.length})`;
    }

    renderGrid();
  } catch (err) {
    loading.textContent = `Error loading objects: ${err.message}`;
  }
}

load();
</script>

<style is:global>
  .corpus-page { padding-block: var(--space-16) var(--space-24); background: var(--bg); min-height: 80vh; }
  .corpus-head { display: flex; align-items: baseline; gap: var(--space-8); flex-wrap: wrap; margin-bottom: var(--space-10); }
  .corpus-title { font-family: var(--font-display); font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl)); letter-spacing: var(--tracking-snug); font-weight: normal; }
  .corpus-sub { font-size: var(--text-base); color: var(--text-muted); flex-basis: 100%; margin-top: calc(-1 * var(--space-6)); max-width: none; }
  .corpus-actions { display: flex; gap: var(--space-3); align-items: center; margin-left: auto; }
  .corpus-action-link {
    font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent);
    text-decoration: none; border: 1px solid var(--accent);
    padding: var(--space-2) var(--space-4); border-radius: var(--radius-sm); white-space: nowrap;
  }
  .corpus-action-link:hover { background: var(--accent-dim); }
  .corpus-select-btn {
    font-family: var(--font-mono); font-size: var(--text-sm);
    color: var(--text-muted); background: none; border: 1px solid var(--border);
    padding: var(--space-2) var(--space-4); border-radius: var(--radius-sm); cursor: pointer; white-space: nowrap;
    transition: color var(--ease), border-color var(--ease);
  }
  .corpus-select-btn:hover { color: var(--text); border-color: var(--text-muted); }
  .corpus-select-btn.select-active { color: var(--text); border-color: var(--text); }

  /* Selection card states */
  .card-selectable { cursor: pointer; position: relative; text-align: left; }
  .card-selectable:focus { outline: 2px solid var(--accent); }
  .card-checked { border-color: var(--accent) !important; box-shadow: 0 0 0 2px var(--accent) !important; }
  .card-check-overlay {
    position: absolute; top: var(--space-2); right: var(--space-2); z-index: var(--z-above);
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--bg-surface); border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: var(--weight-bold); color: var(--accent);
    transition: background var(--ease-fast), border-color var(--ease-fast);
  }
  .card-checked .card-check-overlay { background: var(--accent); border-color: var(--accent); color: var(--white); }

  /* Sticky selection bar */
  .selection-bar {
    position: fixed; bottom: var(--space-6); left: 50%; transform: translateX(-50%);
    background: var(--bg-dark); color: var(--text-invert);
    border-radius: var(--radius-full); padding: var(--space-4) var(--space-6);
    display: flex; align-items: center; gap: var(--space-6);
    box-shadow: var(--shadow-overlay); z-index: var(--z-nav);
    white-space: nowrap;
  }
  .sel-count { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--bg-alt); }
  .sel-actions { display: flex; gap: var(--space-3); align-items: center; }
  .sel-clear {
    font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-subtle);
    background: none; border: 1px solid var(--text-dim); border-radius: var(--radius-sm);
    padding: var(--space-1) var(--space-3); cursor: pointer;
  }
  .sel-clear:hover { color: var(--bg-alt); border-color: var(--text-subtle); }
  .sel-compare {
    font-family: var(--font-mono); font-size: var(--text-sm);
    background: var(--accent); color: var(--white); text-decoration: none;
    padding: var(--space-2) var(--space-5); border-radius: var(--radius-sm);
    transition: background var(--ease);
  }
  .sel-compare:hover { background: var(--accent-light); color: var(--white); }

  .corpus-loading, .corpus-empty {
    font-size: var(--text-base);
    color: var(--text-muted);
    padding: var(--space-16) 0;
    max-width: none;
  }
  .corpus-empty a { color: var(--accent); }

  .object-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 1024px) { .object-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 640px)  { .object-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .corpus-head    { flex-direction: column; align-items: flex-start; gap: var(--space-4); }
    .corpus-actions { margin-left: 0; width: 100%; flex-wrap: wrap; }
    .corpus-select-btn, .corpus-action-link { flex: 1; text-align: center; }
  }

  .object-card {
    display: block;
    text-decoration: none;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--ease), box-shadow var(--ease);
    min-width: 0;
  }
  .object-card:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-accent);
  }
  .card-image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--bg-alt);
    display: block;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .card-no-image {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    background: var(--bg-alt);
  }
  .card-body { padding: var(--space-3) var(--space-4); display: flex; flex-direction: column; gap: var(--space-2); }
  .card-display-id { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text); font-weight: var(--weight-semibold); max-width: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .card-culture { font-size: var(--text-sm); color: var(--text-muted); max-width: none; }
  .card-meta { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--space-1); }
  .card-fp-yes  { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: var(--tracking-wide); color: var(--cons); }
  .card-fp-no   { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: var(--tracking-wide); color: var(--text-muted); }
  .card-date    { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); }
  .card-conflict{ font-family: var(--font-mono); font-size: 0.65rem; color: var(--theory); letter-spacing: var(--tracking-wide); }
  .card-ref     { font-family: var(--font-mono); font-size: 0.65rem; color: var(--cons); letter-spacing: var(--tracking-wide); }
  .card-meta-right { display: flex; align-items: center; gap: var(--space-2); }

  /* Filter bar */
  .filter-bar { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-6); flex-wrap: wrap; }
  .filter-btn {
    font-family: var(--font-mono); font-size: var(--text-xs);
    border-radius: var(--radius-sm);
    padding: var(--space-2) var(--space-4); cursor: pointer;
    transition: all var(--ease); letter-spacing: var(--tracking-wide); border: 1px solid;
  }
  .filter-btn-conflict {
    background: var(--theory-bg); color: var(--theory); border-color: var(--color-warn);
  }
  .filter-btn-conflict:hover, .filter-btn-conflict.filter-active { background: var(--theory); color: var(--white); border-color: var(--theory); }
  .filter-btn-reference {
    background: var(--cons-bg); color: var(--cons); border-color: var(--cons);
  }
  .filter-btn-reference:hover, .filter-btn-reference.filter-active { background: var(--cons); color: var(--white); border-color: var(--cons); }
  .filter-count { font-size: var(--text-xs); opacity: 0.8; margin-left: var(--space-2); }
  .filter-clear {
    font-family: var(--font-mono); font-size: var(--text-xs);
    background: none; color: var(--text-muted); border: 1px solid var(--border);
    border-radius: var(--radius-sm); padding: var(--space-2) var(--space-4); cursor: pointer;
  }
  .filter-clear:hover { color: var(--text); border-color: var(--text-muted); }
</style>
