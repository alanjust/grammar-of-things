---
export const prerender = true;
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Corpus — The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
</head>
<body>
  <SiteNav />

  <div class="corpus-page">
    <div class="container">
      <div class="corpus-head">
        <h1 class="corpus-title">Corpus</h1>
        <div class="corpus-actions">
          <button id="selectToggle" class="corpus-select-btn">Select to compare</button>
          <a href="/catalog" class="corpus-action-link">+ Catalog new object</a>
        </div>
        <p class="corpus-sub">All cataloged objects. Click any object to view its fingerprint and run an analysis.</p>
      </div>

      <!-- Filter bar (shown when there are conflict objects) -->
      <div id="filterBar" class="filter-bar" style="display:none">
        <button id="conflictFilter" class="filter-btn">
          ⚠ Sources disagree
          <span id="conflictCount" class="conflict-count"></span>
        </button>
        <button id="clearFilter" class="filter-clear" style="display:none">Show all</button>
      </div>

      <div id="loading" class="corpus-loading">Loading objects…</div>
      <div id="empty" class="corpus-empty" style="display:none">
        No objects cataloged yet. <a href="/catalog">Catalog the first one →</a>
      </div>
      <div id="grid" class="object-grid" style="display:none"></div>

      <!-- Sticky selection bar -->
      <div id="selectionBar" class="selection-bar" style="display:none">
        <span id="selCount" class="sel-count">0 selected</span>
        <div class="sel-actions">
          <button id="clearSelBtn" class="sel-clear">Clear</button>
          <a id="compareLink" href="/compare" class="sel-compare">Compare →</a>
        </div>
      </div>
    </div>
  </div>

  <SiteFooter />

<script>
// ── State ───────────────────────────────────────────────────────────────────
let allObjects = [];
let selectMode = false;
const selectedIds = new Set();

// ── DOM refs ─────────────────────────────────────────────────────────────────
const loading      = document.getElementById('loading');
const empty        = document.getElementById('empty');
const grid         = document.getElementById('grid');
const selBar       = document.getElementById('selectionBar');
const selCount     = document.getElementById('selCount');
const compareLink  = document.getElementById('compareLink');
const clearSelBtn  = document.getElementById('clearSelBtn');
const selectToggle = document.getElementById('selectToggle');

// ── Toggle select mode ───────────────────────────────────────────────────────
selectToggle.addEventListener('click', () => {
  selectMode = !selectMode;
  if (!selectMode) { selectedIds.clear(); updateBar(); }
  selectToggle.textContent = selectMode ? '✕ Cancel selection' : 'Select to compare';
  selectToggle.classList.toggle('select-active', selectMode);
  renderGrid();
});

clearSelBtn.addEventListener('click', () => {
  selectedIds.clear();
  updateBar();
  renderGrid();
});

function updateBar() {
  const n = selectedIds.size;
  selBar.style.display = n > 0 ? '' : 'none';
  selCount.textContent = `${n} object${n !== 1 ? 's' : ''} selected`;
  compareLink.href = `/compare?ids=${[...selectedIds].join(',')}`;
}

// ── Render ────────────────────────────────────────────────────────────────────
function renderGrid() {
  if (!allObjects.length) return;
  const displayObjects = conflictFilterActive
    ? allObjects.filter(o => o.claim_conflict)
    : allObjects;
  if (displayObjects.length === 0) {
    grid.innerHTML = '<p class="corpus-empty">No objects match this filter.</p>';
    return;
  }
  grid.innerHTML = displayObjects.map(obj => {
    const imgKey  = obj.image_analysis_key?.split(',')[0]?.trim();
    const imgSrc  = imgKey ? `/api/image/${imgKey}` : null;
    const culture = obj.attribution_culture ?? '—';
    const accession = obj.accession_number ?? obj.catalog_number ?? `#${obj.id}`;
    const hasFingerprint = !!obj.fingerprinted_at;
    const date = obj.created_at
      ? new Date(obj.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })
      : '';
    const isSelected = selectedIds.has(obj.id);

    if (selectMode) {
      return `
        <button type="button" class="object-card card-selectable ${isSelected ? 'card-checked' : ''}" data-id="${obj.id}">
          <div class="card-check-overlay">${isSelected ? '✓' : ''}</div>
          ${imgSrc
            ? `<div class="card-image"><img src="${imgSrc}" alt="${accession}" loading="lazy" /></div>`
            : `<div class="card-no-image">No image</div>`}
          <div class="card-body">
            <p class="card-accession">${accession}</p>
            <p class="card-culture">${culture}</p>
            <div class="card-meta">
              <span class="${hasFingerprint ? 'card-fp-yes' : 'card-fp-no'}">
                ${hasFingerprint ? '● Fingerprinted' : '○ No fingerprint'}
              </span>
            </div>
          </div>
        </button>`;
    }

    return `
      <a href="/corpus/${obj.id}" class="object-card">
        ${imgSrc
          ? `<div class="card-image"><img src="${imgSrc}" alt="${accession}" loading="lazy" /></div>`
          : `<div class="card-no-image">No image</div>`}
        <div class="card-body">
          <p class="card-accession">${accession}</p>
          <p class="card-culture">${culture}</p>
          <div class="card-meta">
            <span class="${hasFingerprint ? 'card-fp-yes' : 'card-fp-no'}">
              ${hasFingerprint ? '● Fingerprinted' : '○ No fingerprint'}
            </span>
            ${obj.claim_conflict ? '<span class="card-conflict">⚠ disagree</span>' : `<span class="card-date">${date}</span>`}
          </div>
        </div>
      </a>`;
  }).join('');

  // Selection click handlers
  if (selectMode) {
    grid.querySelectorAll('.card-selectable').forEach(btn => {
      btn.addEventListener('click', () => {
        const id = Number(btn.dataset.id);
        if (selectedIds.has(id)) selectedIds.delete(id);
        else selectedIds.add(id);
        updateBar();
        renderGrid();
      });
    });
  }
}

// ── Conflict filter ───────────────────────────────────────────────────────────

let conflictFilterActive = false;
const filterBar     = document.getElementById('filterBar');
const conflictFilter = document.getElementById('conflictFilter');
const conflictCount  = document.getElementById('conflictCount');
const clearFilter    = document.getElementById('clearFilter');

conflictFilter?.addEventListener('click', () => {
  conflictFilterActive = true;
  conflictFilter.classList.add('filter-active');
  clearFilter.style.display = '';
  renderGrid();
});

clearFilter?.addEventListener('click', () => {
  conflictFilterActive = false;
  conflictFilter.classList.remove('filter-active');
  clearFilter.style.display = 'none';
  renderGrid();
});

// ── Load ──────────────────────────────────────────────────────────────────────
async function load() {
  try {
    const res = await fetch('/api/objects');
    if (!res.ok) throw new Error(`${res.status}`);
    allObjects = await res.json();
    loading.style.display = 'none';
    if (!allObjects.length) { empty.style.display = ''; return; }
    grid.style.display = '';

    // Show conflict filter if any objects have disagreeing claims
    const conflictObjs = allObjects.filter(o => o.claim_conflict);
    if (conflictObjs.length > 0) {
      filterBar.style.display = '';
      conflictCount.textContent = `(${conflictObjs.length})`;
    }

    renderGrid();
  } catch (err) {
    loading.textContent = `Error loading objects: ${err.message}`;
  }
}

load();
</script>

<style is:global>
  .corpus-page { padding-block: var(--space-16) var(--space-24); background: var(--bg); min-height: 80vh; }
  .corpus-head { display: flex; align-items: baseline; gap: var(--space-8); flex-wrap: wrap; margin-bottom: var(--space-10); }
  .corpus-title { font-family: var(--font-display); font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl)); letter-spacing: -0.015em; font-weight: normal; }
  .corpus-sub { font-size: var(--text-base); color: var(--text-muted); flex-basis: 100%; margin-top: calc(-1 * var(--space-6)); max-width: none; }
  .corpus-actions { display: flex; gap: var(--space-3); align-items: center; margin-left: auto; }
  .corpus-action-link {
    font-family: var(--font-mono); font-size: var(--text-sm); color: var(--accent);
    text-decoration: none; border: 1px solid var(--accent);
    padding: var(--space-2) var(--space-4); border-radius: 3px; white-space: nowrap;
  }
  .corpus-action-link:hover { background: var(--accent-dim); }
  .corpus-select-btn {
    font-family: var(--font-mono); font-size: var(--text-sm);
    color: var(--text-muted); background: none; border: 1px solid var(--border);
    padding: var(--space-2) var(--space-4); border-radius: 3px; cursor: pointer; white-space: nowrap;
    transition: color 0.2s, border-color 0.2s;
  }
  .corpus-select-btn:hover { color: var(--text); border-color: var(--text-muted); }
  .corpus-select-btn.select-active { color: var(--text); border-color: var(--text); }

  /* Selection card states */
  .card-selectable { cursor: pointer; position: relative; text-align: left; }
  .card-selectable:focus { outline: 2px solid var(--accent); }
  .card-checked { border-color: var(--accent) !important; box-shadow: 0 0 0 2px var(--accent) !important; }
  .card-check-overlay {
    position: absolute; top: var(--space-2); right: var(--space-2); z-index: 2;
    width: 22px; height: 22px; border-radius: 50%;
    background: var(--bg-surface); border: 2px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    font-size: 11px; font-weight: 700; color: var(--accent);
    transition: background 0.15s, border-color 0.15s;
  }
  .card-checked .card-check-overlay { background: var(--accent); border-color: var(--accent); color: #fff; }

  /* Sticky selection bar */
  .selection-bar {
    position: fixed; bottom: var(--space-6); left: 50%; transform: translateX(-50%);
    background: var(--bg-dark); color: var(--text-invert);
    border-radius: 40px; padding: var(--space-4) var(--space-6);
    display: flex; align-items: center; gap: var(--space-6);
    box-shadow: 0 4px 24px rgba(0,0,0,0.3); z-index: 200;
    white-space: nowrap;
  }
  .sel-count { font-family: var(--font-mono); font-size: var(--text-sm); color: #ede9e2; }
  .sel-actions { display: flex; gap: var(--space-3); align-items: center; }
  .sel-clear {
    font-family: var(--font-mono); font-size: var(--text-xs); color: #8a8079;
    background: none; border: 1px solid #4a4540; border-radius: 3px;
    padding: var(--space-1) var(--space-3); cursor: pointer;
  }
  .sel-clear:hover { color: #ede9e2; border-color: #8a8079; }
  .sel-compare {
    font-family: var(--font-mono); font-size: var(--text-sm);
    background: var(--accent); color: #fff; text-decoration: none;
    padding: var(--space-2) var(--space-5); border-radius: 3px;
    transition: background 0.2s;
  }
  .sel-compare:hover { background: var(--accent-light); color: #fff; }

  .corpus-loading, .corpus-empty {
    font-size: var(--text-base);
    color: var(--text-muted);
    padding: var(--space-16) 0;
    max-width: none;
  }
  .corpus-empty a { color: var(--accent); }

  .object-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 1024px) { .object-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 640px)  { .object-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 640px) {
    .corpus-head    { flex-direction: column; align-items: flex-start; gap: var(--space-4); }
    .corpus-actions { margin-left: 0; width: 100%; flex-wrap: wrap; }
    .corpus-select-btn, .corpus-action-link { flex: 1; text-align: center; }
  }

  .object-card {
    display: block;
    text-decoration: none;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    min-width: 0;
  }
  .object-card:hover {
    border-color: var(--accent);
    box-shadow: 0 2px 10px rgba(155, 79, 25, 0.1);
  }
  .card-image {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    background: var(--bg-alt);
    display: block;
  }
  .card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .card-no-image {
    width: 100%;
    aspect-ratio: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    color: var(--text-muted);
    font-family: var(--font-mono);
    background: var(--bg-alt);
  }
  .card-body { padding: var(--space-3) var(--space-4); display: flex; flex-direction: column; gap: var(--space-2); }
  .card-accession { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text); font-weight: 600; max-width: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .card-culture { font-size: var(--text-sm); color: var(--text-muted); max-width: none; }
  .card-meta { display: flex; justify-content: space-between; align-items: center; flex-wrap: wrap; gap: var(--space-1); }
  .card-fp-yes  { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.03em; color: var(--cons); }
  .card-fp-no   { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: 0.03em; color: var(--text-muted); }
  .card-date    { font-family: var(--font-mono); font-size: 0.65rem; color: var(--text-muted); }
  .card-conflict{ font-family: var(--font-mono); font-size: 0.65rem; color: var(--theory); letter-spacing: 0.03em; }

  /* Filter bar */
  .filter-bar { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-6); }
  .filter-btn {
    font-family: var(--font-mono); font-size: var(--text-xs);
    background: var(--theory-bg); color: var(--theory);
    border: 1px solid #e5c68a; border-radius: 3px;
    padding: var(--space-2) var(--space-4); cursor: pointer;
    transition: all 0.2s; letter-spacing: 0.03em;
  }
  .filter-btn:hover, .filter-btn.filter-active { background: var(--theory); color: #fff; border-color: var(--theory); }
  .conflict-count { font-size: var(--text-xs); opacity: 0.8; margin-left: var(--space-2); }
  .filter-clear {
    font-family: var(--font-mono); font-size: var(--text-xs);
    background: none; color: var(--text-muted); border: 1px solid var(--border);
    border-radius: 3px; padding: var(--space-2) var(--space-4); cursor: pointer;
  }
  .filter-clear:hover { color: var(--text); border-color: var(--text-muted); }
</style>
