---
export const prerender = true;
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reference Library — The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
  <!-- PDF.js for browser-side text extraction -->
  <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
</head>
<body>
  <SiteNav />

  <div class="lib-page">
    <div class="container">

      <div class="page-head">
        <h1>Reference Library</h1>
        <p class="page-sub">Scholarly sources indexed for retrieval during Pass 2 analysis. Upload a PDF or paste extracted text — the system chunks and indexes it automatically.</p>
      </div>

      <!-- Upload form -->
      <div class="upload-section">
        <h2>Add document</h2>

        <div id="dropZone" class="drop-zone">
          <input type="file" id="fileInput" accept=".pdf,.txt,.md" hidden />
          <p class="drop-icon">↑</p>
          <p class="drop-text">Click to upload a PDF or text file</p>
          <p class="drop-hint">PDF text is extracted in your browser — the original is stored in R2 if available</p>
        </div>

        <div id="extractProgress" class="extract-progress" style="display:none">
          <p id="extractMsg">Extracting text…</p>
        </div>

        <form id="uploadForm" style="display:none">
          <div class="form-grid">
            <div class="field field-wide">
              <label for="fTitle">Title <span class="req">*</span></label>
              <input type="text" id="fTitle" placeholder="Mimbres Painted Pottery" required />
            </div>
            <div class="field field-wide">
              <label for="fAuthor">Author(s) <span class="req">*</span></label>
              <input type="text" id="fAuthor" placeholder="Brody, J.J." required />
            </div>
            <div class="field">
              <label for="fYear">Year</label>
              <input type="number" id="fYear" placeholder="2004" min="1800" max="2100" />
            </div>
            <div class="field">
              <label for="fCitationKey">Citation key <span class="req">*</span></label>
              <input type="text" id="fCitationKey" placeholder="BRODY-2004" required
                title="Used inline in analysis: [BRODY-2004, p.127]. Uppercase, no spaces." />
            </div>
            <div class="field">
              <label for="fType">Type</label>
              <select id="fType">
                <option value="book">Book</option>
                <option value="article">Article</option>
                <option value="report">Report</option>
                <option value="excerpt">Excerpt</option>
                <option value="chapter">Chapter</option>
              </select>
            </div>
            <div class="field">
              <label for="fPageStart">First page no.</label>
              <input type="number" id="fPageStart" placeholder="1" min="1"
                title="Starting page number — used to build page references like p.127" />
            </div>
            <div class="field field-wide">
              <label for="fSection">Section / chapter label</label>
              <input type="text" id="fSection" placeholder="Chapter 3: Form and Structure" />
            </div>
            <div class="field field-wide">
              <label for="fDoi">DOI / URL</label>
              <input type="text" id="fDoi" placeholder="https://doi.org/10.1234/..." />
            </div>
            <div class="field field-full">
              <label for="fNotes">Notes</label>
              <input type="text" id="fNotes" placeholder="Primary source for Mimbres formal analysis. Chapter 3-6 most relevant." />
            </div>
          </div>

          <div class="text-preview">
            <label for="fText">Extracted text <span class="req">*</span></label>
            <p class="field-hint">Review or edit before submitting. For scanned PDFs with poor OCR, paste corrected text here.</p>
            <textarea id="fText" rows="10" placeholder="Paste extracted text here, or upload a PDF above…" required></textarea>
            <p id="charCount" class="char-count"></p>
          </div>

          <div class="form-actions">
            <button type="submit" id="submitBtn" class="submit-btn">Index document</button>
            <button type="button" id="cancelBtn" class="cancel-btn">Cancel</button>
          </div>
        </form>

        <div id="uploadStatus" class="upload-status" style="display:none"></div>
      </div>

      <!-- Document list -->
      <div class="library-section">
        <div class="library-head">
          <h2>Indexed documents <span id="docCount" class="doc-count"></span></h2>
          <input type="search" id="searchBox" class="search-box" placeholder="Search titles, authors, citation keys…" />
        </div>
        <div id="docList" class="doc-list">
          <p class="loading">Loading library…</p>
        </div>
      </div>

    </div>
  </div>

  <SiteFooter />

<script>
// ── PDF.js setup ────────────────────────────────────────────────────────────
const pdfjsLib = window['pdfjs-dist/build/pdf'];
if (pdfjsLib) {
  pdfjsLib.GlobalWorkerOptions.workerSrc =
    'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
}

// ── State ───────────────────────────────────────────────────────────────────
let extractedText = '';
let fileBase64    = '';
let fileName      = '';
let allDocs       = [];

// ── DOM refs ─────────────────────────────────────────────────────────────────
const dropZone       = document.getElementById('dropZone');
const fileInput      = document.getElementById('fileInput');
const extractProgress= document.getElementById('extractProgress');
const extractMsg     = document.getElementById('extractMsg');
const uploadForm     = document.getElementById('uploadForm');
const fText          = document.getElementById('fText');
const fTitle         = document.getElementById('fTitle');
const fAuthor        = document.getElementById('fAuthor');
const fYear          = document.getElementById('fYear');
const fCitationKey   = document.getElementById('fCitationKey');
const fType          = document.getElementById('fType');
const fPageStart     = document.getElementById('fPageStart');
const fSection       = document.getElementById('fSection');
const fDoi           = document.getElementById('fDoi');
const fNotes         = document.getElementById('fNotes');
const charCount      = document.getElementById('charCount');
const submitBtn      = document.getElementById('submitBtn');
const cancelBtn      = document.getElementById('cancelBtn');
const uploadStatus   = document.getElementById('uploadStatus');
const searchBox      = document.getElementById('searchBox');
const docList        = document.getElementById('docList');
const docCount       = document.getElementById('docCount');

// ── File upload / text extraction ────────────────────────────────────────────

dropZone.addEventListener('click', () => fileInput.click());
dropZone.addEventListener('dragover', e => { e.preventDefault(); dropZone.classList.add('drag-over'); });
dropZone.addEventListener('dragleave', () => dropZone.classList.remove('drag-over'));
dropZone.addEventListener('drop', e => {
  e.preventDefault();
  dropZone.classList.remove('drag-over');
  const file = e.dataTransfer?.files?.[0];
  if (file) processFile(file);
});
fileInput.addEventListener('change', () => {
  const file = fileInput.files?.[0];
  if (file) processFile(file);
});

async function processFile(file) {
  fileName = file.name;
  dropZone.style.display = 'none';
  extractProgress.style.display = '';

  // Auto-suggest citation key from filename
  const auto = file.name.replace(/\.[^.]+$/, '').toUpperCase().replace(/[^A-Z0-9]/g, '-').slice(0, 20);
  if (!fCitationKey.value) fCitationKey.value = auto;

  try {
    if (file.type === 'application/pdf' || file.name.endsWith('.pdf')) {
      extractMsg.textContent = 'Extracting text from PDF…';

      // Read as ArrayBuffer for PDF.js
      const arrayBuffer = await file.arrayBuffer();

      // Also store as base64 for R2 upload
      const bytes = new Uint8Array(arrayBuffer);
      let binary = '';
      for (let i = 0; i < bytes.length; i += 8192) {
        binary += String.fromCharCode(...bytes.subarray(i, Math.min(i + 8192, bytes.length)));
      }
      fileBase64 = btoa(binary);

      if (!pdfjsLib) {
        extractMsg.textContent = 'PDF.js unavailable — paste text manually below.';
        showForm('');
        return;
      }

      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      extractMsg.textContent = `Extracting ${pdf.numPages} pages…`;

      let text = '';
      for (let i = 1; i <= pdf.numPages; i++) {
        const page = await pdf.getPage(i);
        const content = await page.getTextContent();
        const pageText = content.items.map(item => item.str).join(' ');
        text += pageText + '\n\n';
        if (i % 10 === 0) extractMsg.textContent = `Extracted ${i}/${pdf.numPages} pages…`;
      }
      extractedText = text;
      extractMsg.textContent = `Done — ${pdf.numPages} pages, ~${Math.round(text.length / 5)} words`;
    } else {
      // Plain text / markdown
      extractedText = await file.text();
      fileBase64 = '';
      extractMsg.textContent = `Text file loaded — ~${Math.round(extractedText.length / 5)} words`;
    }

    showForm(extractedText);
  } catch (err) {
    extractMsg.textContent = `Error: ${err.message} — paste text manually below.`;
    showForm('');
  }
}

function showForm(text) {
  extractProgress.style.display = 'none';
  uploadForm.style.display = '';
  fText.value = text;
  updateCharCount();
}

fText.addEventListener('input', () => {
  extractedText = fText.value;
  updateCharCount();
});

function updateCharCount() {
  const words = Math.round(fText.value.length / 5);
  charCount.textContent = `~${words.toLocaleString()} words · ~${Math.round(words * 1.3).toLocaleString()} tokens`;
}

cancelBtn.addEventListener('click', () => {
  uploadForm.style.display = 'none';
  dropZone.style.display = '';
  extractProgress.style.display = 'none';
  extractedText = '';
  fileBase64 = '';
  fileName = '';
  uploadStatus.style.display = 'none';
  uploadStatus.innerHTML = '';
  fileInput.value = '';
});

// ── Form submit ──────────────────────────────────────────────────────────────

uploadForm.addEventListener('submit', async e => {
  e.preventDefault();
  const text = fText.value.trim();
  if (!text) { alert('No text to index.'); return; }

  submitBtn.disabled = true;
  submitBtn.textContent = 'Indexing…';

  try {
    const body = {
      citation_key:  fCitationKey.value.trim().toUpperCase(),
      title:         fTitle.value.trim(),
      author:        fAuthor.value.trim(),
      year:          fYear.value ? Number(fYear.value) : null,
      doc_type:      fType.value,
      doi:           fDoi.value.trim() || null,
      notes:         fNotes.value.trim() || null,
      section_ref:   fSection.value.trim() || null,
      page_start:    fPageStart.value ? Number(fPageStart.value) : null,
      extracted_text: text,
      file_data:     fileBase64 || null,
      file_name:     fileName   || null,
    };

    const res = await fetch('/api/library/upload', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify(body),
    });
    const data = await res.json();

    if (!res.ok) throw new Error(data.error ?? `${res.status}`);

    uploadStatus.style.display = '';
    uploadStatus.innerHTML = `<p class="status-ok">✓ Indexed <strong>${data.citation_key}</strong> — ${data.chunk_count} passages</p>`;
    uploadForm.style.display = 'none';
    dropZone.style.display = '';
    extractedText = ''; fileBase64 = ''; fileName = '';
    fileInput.value = '';
    uploadForm.reset();

    // Refresh list
    await loadDocs();
  } catch (err) {
    uploadStatus.style.display = '';
    uploadStatus.innerHTML = `<p class="status-err">Error: ${err.message}</p>`;
  } finally {
    submitBtn.disabled = false;
    submitBtn.textContent = 'Index document';
  }
});

// ── Document list ────────────────────────────────────────────────────────────

async function loadDocs() {
  try {
    const res = await fetch('/api/library');
    allDocs = await res.json();
    renderDocs(allDocs);
  } catch (err) {
    docList.innerHTML = `<p class="loading">Error loading library: ${err.message}</p>`;
  }
}

function renderDocs(docs) {
  docCount.textContent = `(${docs.length})`;
  if (docs.length === 0) {
    docList.innerHTML = '<p class="empty-lib">No documents indexed yet. Upload the first one above.</p>';
    return;
  }
  docList.innerHTML = docs.map(doc => `
    <div class="doc-row" data-id="${doc.id}">
      <div class="doc-main">
        <p class="doc-key">${doc.citation_key}</p>
        <p class="doc-title">${doc.title}</p>
        <p class="doc-meta">${doc.author}${doc.year ? ' · ' + doc.year : ''}${doc.doc_type ? ' · ' + doc.doc_type : ''}</p>
      </div>
      <div class="doc-right">
        <span class="chunk-count">${doc.chunk_count} passages</span>
        <button class="del-btn" data-id="${doc.id}" aria-label="Delete ${doc.title}">Delete</button>
      </div>
    </div>
  `).join('');

  docList.querySelectorAll('.del-btn').forEach(btn => {
    btn.addEventListener('click', async () => {
      const id = btn.dataset.id;
      const row = btn.closest('.doc-row');
      const title = row.querySelector('.doc-title').textContent;
      if (!confirm(`Delete "${title}" and all its indexed passages?`)) return;
      btn.textContent = '…';
      btn.disabled = true;
      try {
        const res = await fetch(`/api/library/${id}`, { method: 'DELETE' });
        if (res.ok) {
          allDocs = allDocs.filter(d => d.id !== Number(id));
          renderDocs(filterDocs(searchBox.value));
        } else {
          btn.textContent = 'Error';
        }
      } catch { btn.textContent = 'Error'; }
    });
  });
}

function filterDocs(query) {
  if (!query) return allDocs;
  const q = query.toLowerCase();
  return allDocs.filter(d =>
    d.citation_key?.toLowerCase().includes(q) ||
    d.title?.toLowerCase().includes(q) ||
    d.author?.toLowerCase().includes(q)
  );
}

searchBox.addEventListener('input', () => renderDocs(filterDocs(searchBox.value)));

loadDocs();
</script>

<style is:global>
  .lib-page { padding-block: var(--space-16) var(--space-24); background: var(--bg); min-height: 80vh; }
  .lib-page .container { max-width: 900px; }
  .page-head { margin-bottom: var(--space-12); }
  .lib-page h1 { font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl)); letter-spacing: -0.015em; margin-bottom: var(--space-4); }
  .page-sub { font-size: var(--text-base); color: var(--text-muted); line-height: 1.7; max-width: 68ch; }

  /* Upload section */
  .upload-section { background: var(--bg-surface); border: 1px solid var(--border); border-radius: 4px; padding: var(--space-8); margin-bottom: var(--space-12); }
  .upload-section h2 { font-size: var(--text-xl); margin-bottom: var(--space-6); }

  .drop-zone {
    border: 2px dashed var(--border); border-radius: 4px;
    padding: var(--space-10) var(--space-8); text-align: center;
    cursor: pointer; background: var(--bg);
    transition: border-color 0.2s, background 0.2s;
  }
  .drop-zone:hover, .drop-zone.drag-over { border-color: var(--accent); background: var(--accent-dim); }
  .drop-icon  { font-size: var(--text-3xl); color: var(--border-strong); margin-bottom: var(--space-2); max-width: none; }
  .drop-text  { font-size: var(--text-base); color: var(--text); max-width: none; margin-bottom: var(--space-1); }
  .drop-hint  { font-size: var(--text-sm); color: var(--text-muted); max-width: none; }

  .extract-progress { padding: var(--space-6) 0; }
  .extract-progress p { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text-muted); max-width: none; }

  /* Form */
  .form-grid { display: grid; grid-template-columns: 1fr 1fr; gap: var(--space-4); margin-bottom: var(--space-6); }
  .field { display: flex; flex-direction: column; gap: var(--space-2); }
  .field-wide { grid-column: span 2; }
  .field-full { grid-column: 1 / -1; }
  .field label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); letter-spacing: 0.04em; }
  .req { color: var(--accent); }
  .field input, .field select {
    font-family: var(--font-body); font-size: var(--text-sm);
    border: 1px solid var(--border); border-radius: 3px;
    padding: var(--space-2) var(--space-3); background: var(--bg); color: var(--text);
  }
  .field input:focus, .field select:focus { outline: 2px solid var(--accent); border-color: var(--accent); }

  .text-preview { margin-bottom: var(--space-6); }
  .text-preview label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); letter-spacing: 0.04em; display: block; margin-bottom: var(--space-2); }
  .field-hint { font-size: var(--text-xs); color: var(--text-muted); margin-bottom: var(--space-3); max-width: none; }
  .text-preview textarea {
    width: 100%; font-family: var(--font-mono); font-size: var(--text-xs); line-height: 1.6;
    border: 1px solid var(--border); border-radius: 3px; padding: var(--space-4) var(--space-5);
    background: var(--bg); color: var(--text); resize: vertical; min-height: 200px;
  }
  .char-count { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin-top: var(--space-2); max-width: none; }

  .form-actions { display: flex; gap: var(--space-4); }
  .submit-btn {
    background: var(--accent); color: #fff; border: none; border-radius: 3px;
    padding: var(--space-3) var(--space-8); font-family: var(--font-mono);
    font-size: var(--text-sm); cursor: pointer; transition: background 0.2s;
  }
  .submit-btn:hover:not(:disabled) { background: var(--accent-light); }
  .submit-btn:disabled { opacity: 0.45; cursor: not-allowed; }
  .cancel-btn {
    background: none; color: var(--text-muted); border: 1px solid var(--border);
    border-radius: 3px; padding: var(--space-3) var(--space-6);
    font-family: var(--font-mono); font-size: var(--text-sm); cursor: pointer;
  }

  .upload-status { margin-top: var(--space-4); }
  .status-ok  { font-size: var(--text-sm); color: var(--cons); max-width: none; }
  .status-err { font-size: var(--text-sm); color: #c0392b; max-width: none; }

  /* Document list */
  .library-section { }
  .library-head { display: flex; align-items: center; gap: var(--space-6); margin-bottom: var(--space-6); flex-wrap: wrap; }
  .library-head h2 { font-size: var(--text-2xl); }
  .doc-count { font-size: var(--text-lg); color: var(--text-muted); }
  .search-box {
    margin-left: auto; font-family: var(--font-body); font-size: var(--text-sm);
    border: 1px solid var(--border); border-radius: 3px;
    padding: var(--space-2) var(--space-4); background: var(--bg-surface); color: var(--text);
    width: 240px;
  }
  .search-box:focus { outline: 2px solid var(--accent); border-color: var(--accent); }

  .doc-list { display: flex; flex-direction: column; gap: var(--space-2); }
  .loading, .empty-lib { font-size: var(--text-base); color: var(--text-muted); padding: var(--space-8) 0; max-width: none; }

  .doc-row {
    display: flex; align-items: center; gap: var(--space-6);
    background: var(--bg-surface); border: 1px solid var(--border);
    border-radius: 4px; padding: var(--space-4) var(--space-6);
  }
  .doc-main { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: var(--space-1); }
  .doc-key  { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--accent); letter-spacing: 0.04em; max-width: none; }
  .doc-title { font-size: var(--text-base); color: var(--text); font-weight: 500; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: none; }
  .doc-meta  { font-size: var(--text-xs); color: var(--text-muted); max-width: none; }
  .doc-right { display: flex; align-items: center; gap: var(--space-4); flex-shrink: 0; }
  .chunk-count { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .del-btn {
    font-family: var(--font-mono); font-size: var(--text-xs);
    color: var(--text-muted); background: none; border: 1px solid var(--border);
    border-radius: 2px; padding: var(--space-1) var(--space-3); cursor: pointer;
    transition: color 0.2s, border-color 0.2s;
  }
  .del-btn:hover { color: #c0392b; border-color: #c0392b; }

  @media (max-width: 640px) {
    .form-grid { grid-template-columns: 1fr; }
    .field-wide, .field-full { grid-column: span 1; }
    .library-head { flex-direction: column; align-items: flex-start; }
    .search-box { width: 100%; margin-left: 0; }
  }
</style>
