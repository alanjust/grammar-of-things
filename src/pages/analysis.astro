---
export const prerender = true;
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

const fingerprint = [
  { code: 'ap_1',  name: 'Production Trace Reading',         score: 3, desc: 'Coil marks, line discipline, brush control all directly readable' },
  { code: 'ap_2',  name: 'Sequence Inference',               score: 2, desc: 'Slip application, paint program, firing — stages inferrable' },
  { code: 'ap_3',  name: 'Material Boundary Attention',      score: 2, desc: 'Slip/paint/clay interfaces distinct at rim and base' },
  { code: 'ap_4',  name: 'Wear Differential',                score: 1, desc: 'Limited differential observable; fire cloud masking exterior' },
  { code: 'ap_5',  name: 'Absence as Evidence',              score: 2, desc: 'Post-depositional cracking vs. any deliberate perforation reads as distinct evidence type' },
  { code: 'ap_6',  name: 'Composite Detection',              score: 0, desc: 'Single-material vessel; no composite construction' },
  { code: 'ap_7',  name: 'Anatomical Correspondence',        score: 0, desc: 'Pure geometric design; no figurative content' },
  { code: 'ap_8',  name: 'Symmetry as Evidence',             score: 3, desc: 'Bilateral symmetry is a structural commitment in the geometric program' },
  { code: 'ap_9',  name: 'Proportion as Encoding',           score: 2, desc: 'Framing band weight vs. interior field establishes spatial hierarchy' },
  { code: 'ap_10', name: 'Color Zone Logic',                 score: 3, desc: 'Two-zone black/white organization is the entire design system' },
  { code: 'ap_11', name: 'Investment Gradient',              score: 3, desc: 'Interior investment far exceeds exterior — deliberate hierarchy' },
  { code: 'ap_12', name: 'Attachment Point Reading',         score: 0, desc: 'No holes, grooves, or binding residue observable' },
  { code: 'ap_13', name: 'Orientation Dependency',           score: 1, desc: 'Bowl orientation affects legibility of design directionality' },
  { code: 'ap_14', name: 'Completion State',                 score: 2, desc: 'Complete vessel with post-depositional damage only; no production interruption' },
  { code: 'ap_15', name: 'Reduction vs. Construction',       score: 1, desc: 'Coil-and-scrape construction; reduction not applicable' },
  { code: 'ta_1',  name: 'Edge Detection',                   score: 3, desc: 'Angular line quality at turns is primary production evidence' },
  { code: 'ta_2',  name: 'Color Opponent Channels',          score: 3, desc: 'Black/white contrast is the organizing system — nothing else is present' },
  { code: 'ta_4',  name: 'Figure-Ground Relationships',      score: 3, desc: 'Positive-negative ambiguity: dark forms and white channels read interchangeably as figure' },
  { code: 'ta_5',  name: 'Grouping',                         score: 2, desc: 'Angular elements cluster into stepped-diamond compositional units' },
  { code: 'ta_13', name: 'Overlap / Occlusion',              score: 1, desc: 'Minimal implied depth in flat geometric composition' },
  { code: 'ta_15', name: 'Closure / Negative Space',         score: 3, desc: 'White ground channels are designed, not residual — negative space is active' },
  { code: 'ta_20', name: 'Simultaneous Contrast',            score: 2, desc: 'Hard-edge black/white juxtaposition amplifies both zones' },
  { code: 'ta_28', name: 'Specularity / Surface Reflection', score: 1, desc: 'Matte mineral paint; slip shows limited differential sheen' },
  { code: 'ta_47', name: 'Face Detection',                   score: 0, desc: 'No figurative faces; pure geometric program' },
  { code: 'ta_48', name: 'Biological Motion Detection',      score: 0, desc: 'No figurative content of any kind' },
  { code: 'ta_49', name: 'Gaze Direction / Social Attention',score: 0, desc: 'No figurative content' },
  { code: 'ta_51', name: 'Visual Pop-out',                   score: 2, desc: 'Angular geometric elements pop from ground via high-contrast boundary' },
];

function scoreColor(s: number) {
  return s === 0 ? 'sc-0' : s === 1 ? 'sc-1' : s === 2 ? 'sc-2' : 'sc-3';
}
const ap = fingerprint.slice(0, 15);
const ta = fingerprint.slice(15);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Analysis — Bowl A326247 · The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
</head>
<body>
  <SiteNav />

  <div class="analysis-page">
    <div class="container">

      <a href="/" class="back-link">← The Grammar of Things</a>

      <!-- Object record -->
      <header class="object-header">
        <div class="object-images">
          <figure>
            <img src="/images/bowl-interior.jpg" alt="Bowl A326247 — interior view showing geometric design" />
            <figcaption>Interior</figcaption>
          </figure>
          <figure>
            <img src="/images/bowl-exterior.jpg" alt="Bowl A326247 — exterior/profile view" />
            <figcaption>Exterior / profile</figcaption>
          </figure>
        </div>
        <div class="object-info">
          <p class="object-eyebrow">Complete analysis · Proof of concept specimen</p>
          <h1>Bowl <span class="accession">A326247</span></h1>
          <dl class="catalog">
            <div><dt>Object</dt><dd>Bowl — ceramic vessel</dd></div>
            <div><dt>Culture</dt><dd>Mimbres</dd></div>
            <div><dt>Location</dt><dd>Mimbres Valley, Luna County, New Mexico</dd></div>
            <div><dt>Collector</dt><dd>J.W. Fewkes, 1923</dd></div>
            <div><dt>Catalog no.</dt><dd>A326247-0</dd></div>
            <div><dt>Accession</dt><dd>070367 · Bureau of American Ethnology donation, 1 Aug 1923</dd></div>
            <div><dt>Institution</dt><dd>National Museum of Natural History, Smithsonian Institution</dd></div>
            <div><dt>Manufacturing</dt><dd>Painted</dd></div>
            <div><dt>EZID / ARK</dt><dd><a href="http://n2t.net/ark:/65665/3510387fe-08a1-4a08-9876-b3829fc74186" target="_blank" rel="noopener">n2t.net/ark:/65665/3510387fe…</a></dd></div>
          </dl>
          <div class="legend-mini">
            <span class="label label-obs">[OBS]</span> Direct observation &nbsp;
            <span class="label label-interp">[INTERP]</span> Interpretation &nbsp;
            <span class="label label-cons">[CONS]</span> Scholarly consensus &nbsp;
            <span class="label label-theory">[THEORY]</span> Theoretical framework
          </div>
        </div>
      </header>

      <!-- Pass 1 -->
      <section class="pass-section">
        <div class="pass-label">
          <span class="pass-num">Pass 1</span>
          <span class="pass-name">Blind observation</span>
          <span class="pass-note">Documentation excluded from context. Image only.</span>
        </div>
        <div class="pass-body">
          <p>
            <strong>Production Trace Reading:</strong> The exterior surface shows oblique diagonal striations crossing the fire-cloud zones, consistent with coil-and-scrape construction technique.
            <span class="label label-obs">[OBS]</span>
            The interior slip covers the full bowl interior uniformly, adhering without visible underlayer exposure or delamination at any point.
            <span class="label label-obs">[OBS]</span>
            Line work within the design is single-stroke throughout — angular direction changes are controlled and not blunted; no evidence of hesitation, repair, or painted-over correction is visible at turns or junctions.
            <span class="label label-obs">[OBS]</span>
          </p>
          <p>
            <strong>Edge Detection + Color Zone Logic:</strong> The design area is organized as an interior-dominant composition, with two concentric framing lines at the rim establishing the design zone boundary and a large central field below.
            <span class="label label-obs">[OBS]</span>
            The primary design vocabulary is strictly angular — stepped diagonal forms, triangular wedge elements, and interlocking rectilinear channels — with no curvilinear elements present anywhere in the composition.
            <span class="label label-obs">[OBS]</span>
            The slip ground reads as brilliant white to cream; the painted elements are a matte dark brown-black consistent with a single mineral pigment applied from one prepared source.
            <span class="label label-obs">[OBS]</span>
            No warm secondary pigment is detectable; this is a single-pigment design program throughout.
            <span class="label label-obs">[OBS]</span>
          </p>
          <p>
            <strong>Figure-Ground Relationships:</strong> The composition exhibits a designed positive-negative relationship. The dark angular forms and the white ground channels read interchangeably as figure and ground — the design functions as dark angular elements on a white field or equally as white angular channels cut through a dark field.
            <span class="label label-obs">[OBS]</span>
            This is a structural property of how the composition was built, not an incidental effect.
            <span class="label label-obs">[OBS]</span>
          </p>
          <p>
            <strong>Symmetry as Evidence + Proportion as Encoding:</strong> The geometric program organizes around a central stepped-diamond medallion form, with mirror elements reading across at least one bilateral axis and possibly two.
            <span class="label label-obs">[OBS]</span>
            The framing band at the rim carries proportionally heavier line weight than the interior elements, establishing a clear spatial hierarchy between the rim zone and the central field.
            <span class="label label-obs">[OBS]</span>
          </p>
          <p>
            <strong>Completion State + Condition:</strong> A zone of post-depositional cracking is visible in the upper right quadrant of the interior — the crack character, edge profile, and irregular propagation line are consistent with post-firing mechanical breakage, not production failure or intentional perforation.
            <span class="label label-obs">[OBS]</span>
            This damage is distinct from any deliberate modification and does not interrupt the design zone.
            <span class="label label-obs">[OBS]</span>
          </p>
          <p>
            <strong>Investment Gradient (exterior vs. interior):</strong> Investment in the interior surface — controlled slip application, disciplined line work, complex angular geometric design program — far exceeds that of the exterior, which carries no painted design and shows heavy fire cloud darkening across the majority of the surface.
            <span class="label label-obs">[OBS]</span>
            This differential is deliberate and characterizes the production strategy.
            <span class="label label-obs">[OBS]</span>
          </p>
          <p>
            <strong>Exterior profile view:</strong> The exterior surface is heavily fire-clouded; dark zones cover most of the exterior body and base with lighter areas visible toward the rim, where some of the exterior was partially shielded.
            <span class="label label-obs">[OBS]</span>
            Bowl form from profile: open bowl, moderate depth, walls curving inward slightly toward the rim with a rounded base.
            <span class="label label-obs">[OBS]</span>
            Estimated rim diameter approximately 20–25 cm from scale bar; depth approximately 10–12 cm — both estimates from photograph, not physical measurement.
            <span class="label label-obs">[OBS — scale estimate from scale bar; physical measurement required to confirm]</span>
          </p>
        </div>
      </section>

      <!-- Fingerprint -->
      <section class="pass-section fp-section">
        <div class="pass-label">
          <span class="pass-num">Fingerprint</span>
          <span class="pass-name">27-principle perceptual vector</span>
          <span class="pass-note">Computed from Pass 1 observation alone. Stored against the object record.</span>
        </div>
        <div class="fp-body">
          <div class="fp-group">
            <p class="fp-group-title">Artifact-domain principles (ap_1–ap_15)</p>
            {ap.map(p => (
              <div class="fp-row">
                <span class="fp-code">{p.code}</span>
                <div class="fp-bar-wrap"><div class={`fp-bar ${scoreColor(p.score)}`} style={`width:${(p.score/3)*100}%`}></div></div>
                <span class={`fp-score ${scoreColor(p.score)}`}>{p.score}</span>
                <span class="fp-name">{p.name}</span>
                <span class="fp-desc">{p.desc}</span>
              </div>
            ))}
          </div>
          <div class="fp-group">
            <p class="fp-group-title">Universal Tier A principles (applicable subset)</p>
            {ta.map(p => (
              <div class="fp-row">
                <span class="fp-code">{p.code}</span>
                <div class="fp-bar-wrap"><div class={`fp-bar ${scoreColor(p.score)}`} style={`width:${(p.score/3)*100}%`}></div></div>
                <span class={`fp-score ${scoreColor(p.score)}`}>{p.score}</span>
                <span class="fp-name">{p.name}</span>
                <span class="fp-desc">{p.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </section>

      <!-- Pass 2 -->
      <section class="pass-section">
        <div class="pass-label">
          <span class="pass-num">Pass 2</span>
          <span class="pass-name">Artifact analysis</span>
          <span class="pass-note">Documentation now available as context. Audience: researcher.</span>
        </div>
        <div class="pass-body">
          <p>
            <strong>Tradition identification:</strong> The slip and paint program routes this object through CHECK 1 of the tradition identification matrix: brilliant white to cream slip with a single dark pigment
            <span class="label label-obs">[OBS]</span>
            routes to CHECK 2 (Mimbres vs. Ancestral Puebloan disambiguation).
            <span class="label label-cons">[CONS]</span>
            CHECK 2 resolves immediately: the interior-dominant central medallion composition, angular stepped-diamond geometric program, single pigment, and coil-and-scrape construction all converge on Classic Mimbres Black-on-white.
            <span class="label label-cons">[CONS — Brody 2004, Shafer 2003]</span>
            This is a primary-source-supported attribution with five independent converging indicators.
            <span class="label label-interp">[INTERP — tradition_routing_basis: metadata_confirmed; catalog attribution agrees with visual routing]</span>
          </p>
          <p>
            <strong>Construction and forming quality:</strong> Coil-and-scrape is the universal Mimbres construction method.
            <span class="label label-cons">[CONS — Brody, Shafer]</span>
            The oblique striations confirm it here.
            <span class="label label-obs">[OBS]</span>
            Consistent with Shafer's assessment that Mimbres vessels "are often lopsided and rarely symmetrical" — the Mimbreños were technically accomplished potters but not the most precise formers in the Southwest — technical forming quality and design execution should be assessed on independent axes.
            <span class="label label-cons">[CONS — Shafer, NAN Ranch]</span>
            The framing band and interior design field appear well-proportioned, consistent with a competent forming base.
            <span class="label label-obs">[OBS]</span>
          </p>
          <p>
            <strong>Paint quality and design execution:</strong> "Indifferent draftsmanship voided visual success no matter how fertile the imagination. Superb draftsmen who followed the rules could hardly go wrong" (Brody, Form and Structure).
            <span class="label label-theory">[THEORY — Brody paint quality standard]</span>
            The line work on this vessel shows consistent width at angular turns, controlled edge quality, and no evidence of hesitation or repair.
            <span class="label label-obs">[OBS]</span>
            This places the execution in the competent-to-skilled range by Mimbres production standards.
            <span class="label label-interp">[INTERP — Brody paint quality framework]</span>
          </p>
          <p>
            <strong>Design system — positive-negative ambiguity:</strong> The angular stepped-diamond geometric program exhibits what Brody identifies as positive-negative ambiguity: the capacity of the composition to be read simultaneously as dark-on-light or light-on-dark.
            <span class="label label-interp">[INTERP — Brody; Mimbres geometric only]</span>
            This is not a general formal virtue — it is a specific technical achievement built into the Mimbres geometric system, a property that must be constructed deliberately in the design program, not a byproduct of black-on-white contrast alone.
            <span class="label label-theory">[THEORY — iconographic program analysis, Brody/Schaafsma]</span>
            The interlocking angular channels on this vessel demonstrate this capacity.
            <span class="label label-obs">[OBS]</span>
          </p>
          <p>
            <strong>Design system — angular vocabulary:</strong> The strict rectilinearity of this design program — stepped diagonals, angular wedge forms, no curvilinear elements — places it within the angular geometric tradition of Classic Mimbres work rather than the curvilinear or figurative traditions.
            <span class="label label-cons">[CONS — Brody corpus]</span>
            The stepped-diamond medallion organization is a recognizable Mimbres geometric type with documented parallels in the Swarts Ruin and NAN Ranch assemblages.
            <span class="label label-cons">[CONS — Brody 2004, Shafer 2003]</span>
          </p>
          <p>
            <strong>Firing:</strong> Fire clouds on the exterior are expected in Mimbres production and were deliberately tolerated — not an error.
            <span class="label label-cons">[CONS — Brody]</span>
            The heavy darkening on this vessel is consistent with normal Mimbres firing practice; it does not affect attribution or quality assessment.
            <span class="label label-interp">[INTERP — Brody firing notes]</span>
          </p>
          <p>
            <strong>Function category:</strong> The form (open bowl, moderate depth, interior-dominant design) is consistent with the full range of Mimbres bowl use contexts — domestic, serving, and mortuary.
            <span class="label label-obs">[OBS]</span>
            Fewkes collected this object from Mimbres Valley in 1923 in the context of archaeological excavation of burial contexts; the Bureau of American Ethnology donation is consistent with mortuary assemblage material.
            <span class="label label-cons">[CONS — collection context]</span>
            Mortuary attribution requires provenience confirmation; without stratum and burial feature documentation, it remains a well-supported hypothesis rather than a confirmed reading.
            <span class="label label-interp">[INTERP — function_confidence: hypothesis; two anchors: collection context + tradition convention]</span>
          </p>
          <p>
            <strong>Image analysis ceiling:</strong> This analysis cannot determine actual dimensions (no physical measurement), paste temper type (requires petrographic analysis), paint chemistry confirmation (requires pXRF or microscopy), or absolute date (requires thermoluminescence or associated radiocarbon). The tradition attribution, approximate temporal range (~850–1150 CE), design quality assessment, and function hypothesis are supported by image evidence. All other interpretive extensions require physical examination.
          </p>
        </div>
      </section>

      <!-- RAP flags -->
      <section class="pass-section">
        <div class="pass-label">
          <span class="pass-num">RAP Protocol</span>
          <span class="pass-name">Interpretive claims</span>
          <span class="pass-note">Every interpretive claim is anchored. Claims with fewer than two independent observations are labeled hypotheses.</span>
        </div>
        <div class="rap-flags">
          <div class="rap-flag">
            <div class="rap-meta">
              <span class="conf-badge reading">reading</span>
              <span class="claim-type">tradition attribution</span>
              <span class="anchors">5 anchors</span>
            </div>
            <p class="rap-claim">Classic Mimbres Black-on-white (~850–1150 CE): brilliant white slip, single dark mineral pigment, interior-dominant central medallion, angular geometric design, coil-and-scrape construction all converge.</p>
            <p class="rap-gloss">Five independent indicators. "Reading" means the evidence makes the claim, not a guess. Metadata (Smithsonian catalog: "Culture: Mimbres") confirms visual routing — no conflict.</p>
          </div>
          <div class="rap-flag">
            <div class="rap-meta">
              <span class="conf-badge hypothesis">hypothesis</span>
              <span class="claim-type">functional claim</span>
              <span class="anchors">2 anchors</span>
            </div>
            <p class="rap-claim">Mortuary context probable: Fewkes 1923 excavation of Mimbres Valley burial contexts + tradition convention for bowl deposition. Burial confirmation requires provenience documentation (stratum, feature number, associated assemblage).</p>
            <p class="rap-gloss">Two anchors: collection context and Mimbres burial bowl tradition. "Hypothesis" because provenience documentation to confirm stratum and burial association is unavailable in this record.</p>
          </div>
          <div class="rap-flag">
            <div class="rap-meta">
              <span class="conf-badge reading">reading</span>
              <span class="claim-type">iconographic meaning</span>
              <span class="anchors">3 anchors</span>
            </div>
            <p class="rap-claim">Positive-negative ambiguity is a deliberately built structural property of this composition — not incidental. The design functions as both dark forms on white and white channels through dark, simultaneously.</p>
            <p class="rap-gloss">Three formal observations anchor this (bilateral symmetry of the design field, interlocking angular channels, no compositional "remainder" in either reading). Brody identifies this as a specific technical achievement of the Mimbres geometric system.</p>
          </div>
        </div>
      </section>

      <!-- Pass 3 -->
      <section class="pass-section">
        <div class="pass-label">
          <span class="pass-num">Pass 3</span>
          <span class="pass-name">What to take forward</span>
          <span class="pass-note">Skills demonstrated by this analysis. Written for the person who received it.</span>
        </div>
        <div class="pass-body">
          <h3>Ways of looking</h3>
          <p>
            The first thing this analysis did was read the exterior fire clouds as normal, not as evidence of a problem. That move — knowing what counts as an error and what counts as expected practice — is something you can carry to any Southwest vessel. Fire clouds on Mimbres exterior surfaces are tolerated production byproducts, not firing failures. The interior is what matters, and the investment differential between interior and exterior is itself data: it tells you where the maker's attention was directed.
          </p>
          <p>
            The second move was separating the question of forming quality from the question of design quality. This vessel was made with competent but not exceptional forming — the slip application is even, but this is not a technically precise piece by Southwest standards. The painting, by contrast, shows controlled line work at difficult angular turns. Brody's framework treats these as independent axes for good reason: in Mimbres production, the skill that built the vessel and the skill that painted it were sometimes not the same skill, possibly not even the same hands.
          </p>
          <p>
            The third move was naming the positive-negative capacity as a structural property, not an aesthetic accident. When you see a Mimbres geometric design that works "both ways" — dark on white and white on dark — that is a thing the maker built into the composition deliberately, not something that happened. Knowing to look for it, and knowing that it is a specific technical achievement documented in the scholarship, changes how you read the next geometric bowl you encounter.
          </p>
          <h3>What this artifact makes visible</h3>
          <p>
            This bowl makes unusually clear what a single-pigment design system can do when pushed to its structural limit. There is nothing here except white ground and dark paint, organized with precision. No figurative content, no secondary color, no decorative element outside the geometric program. What makes it work — or not work — is entirely the quality of the spatial logic: whether the stepped forms hold their proportional relationships, whether the positive and negative zones are truly balanced, whether the framing contains the field. You can read all of that from the image alone, and that reading transfers directly to the next geometric bowl you see.
          </p>
        </div>
      </section>

      <!-- Fingerprint comparison -->
      <section class="pass-section comparison-section">
        <div class="pass-label">
          <span class="pass-num">Comparison</span>
          <span class="pass-name">Blind fingerprint vs. documented attribution</span>
          <span class="pass-note">Research flag only — not a conclusion about authenticity or attribution.</span>
        </div>
        <div class="comparison-body">
          <div class="comparison-result aligned">
            <span class="result-badge">Aligned</span>
            <span class="result-strength">flag strength: none</span>
          </div>
          <p>
            The perceptual fingerprint — computed from the image alone, before documentation was consulted — is consistent with what the published Mimbres corpus would predict for Classic Mimbres geometric bowl production.
            High scores on Color Zone Logic (3), Edge Detection (3), Figure-Ground (3), Production Trace Reading (3), and Symmetry (3) match the expected fingerprint profile of single-pigment angular geometric Mimbres work.
            The documented attribution (Culture: Mimbres, Smithsonian catalog) agrees with the visual routing result.
            No divergence flag is warranted.
          </p>
          <p class="comparison-caveat">
            <strong>Caveat:</strong> This comparison has no reference corpus behind it yet. The fingerprint alignment claim is based on general knowledge of Mimbres visual characteristics, not on a database of documented comparison objects. The evidentiary value of fingerprint comparison scales directly with the size and quality of the reference corpus — which is what the grant builds.
          </p>
        </div>
      </section>

    </div><!-- end container -->
  </div><!-- end analysis-page -->

  <SiteFooter />
</body>
</html>

<style>
  .analysis-page {
    padding-block: var(--space-12) var(--space-24);
    background: var(--bg);
  }
  .back-link {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: 0.04em;
    margin-bottom: var(--space-12);
  }
  .back-link:hover { color: var(--accent); }

  /* Object header */
  .object-header {
    display: grid;
    grid-template-columns: 360px 1fr;
    gap: var(--space-10);
    align-items: start;
    margin-bottom: var(--space-16);
    padding-bottom: var(--space-12);
    border-bottom: 2px solid var(--border-strong);
  }
  .object-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .object-images figure { margin: 0; }
  .object-images img {
    width: 100%;
    height: auto;
    aspect-ratio: 1;
    object-fit: cover;
    object-position: center top;
    border: 1px solid var(--border);
    border-radius: 3px;
    display: block;
  }
  figcaption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-top: var(--space-2);
    text-align: center;
    letter-spacing: 0.04em;
  }
  .object-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    margin-bottom: var(--space-3);
    max-width: none;
  }
  h1 {
    font-family: var(--font-display);
    font-size: var(--text-4xl);
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }
  .accession { color: var(--accent); }
  .catalog {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-bottom: var(--space-6);
  }
  .catalog div {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: var(--space-4);
    font-size: var(--text-sm);
    padding-block: var(--space-1);
    border-bottom: 1px solid var(--bg-alt);
  }
  dt { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); letter-spacing: 0.03em; padding-top: 2px; }
  dd { color: var(--text); line-height: 1.5; }
  dd a { color: var(--accent); font-family: var(--font-mono); font-size: var(--text-xs); }
  .legend-mini {
