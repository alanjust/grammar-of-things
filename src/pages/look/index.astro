---
export const prerender = true;

import {
  EXPERIENCE_NAME,
  TIER_LABELS,
  TIER_CLASSES,
  BOWL_CARDS,
  PITCHER_IMAGE_URL,
  PITCHER_CREDIT,
  PITCHER_REVEALS,
  STAGE_0_TEXT,
  STAGE_0_BUTTON,
  STAGE_FINAL_INTRO,
  STAGE_FINAL_BUTTON,
  STAGE_FINAL_CLOSE,
} from '../../data/look-content';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="A guided act of looking at an archaeological object." />
  <title>{EXPERIENCE_NAME} — The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
  <style>
    /* ── Layout shell ── */
    .look-shell {
      min-height: 100dvh;
      display: flex;
      flex-direction: column;
      background: var(--bg-dark);
      color: var(--text-invert);
    }

    .look-back {
      position: fixed;
      top: var(--space-4);
      left: var(--space-6);
      z-index: 300;
      font-family: var(--font-body);
      font-size: var(--text-sm);
      color: rgba(244,241,236,0.45);
      text-decoration: none;
      letter-spacing: 0.02em;
      transition: color var(--ease);
    }
    .look-back:hover { color: var(--text-invert); }

    /* ── Stage wrapper ── */
    .look-stage {
      display: none;
      flex-direction: column;
      align-items: center;
      justify-content: flex-start;
      min-height: 100dvh;
      padding: var(--space-12) var(--space-6) var(--space-8);
    }
    .look-stage.is-active { display: flex; }

    /* ── Image wrapper + overlay ── */
    .look-image-wrap {
      position: relative;
      display: inline-block;
      max-width: min(680px, 100%);
      width: 100%;
      margin-inline: auto;
      flex-shrink: 0;
    }
    .look-image-wrap img {
      display: block;
      width: 100%;
      height: auto;
      border-radius: 4px;
    }

    /* Overlay: hidden by default; visible after reveal */
    .look-overlay {
      position: absolute;
      inset: 0;
      pointer-events: none;
      opacity: 0;
      transition: opacity 0.5s ease;
      border-radius: 4px;
      overflow: hidden;
    }
    .look-overlay.is-visible { opacity: 1; }

    /* The dim layer covers the whole image */
    .look-dim {
      position: absolute;
      inset: 0;
      background: rgba(28, 25, 23, 0.62);
      border-radius: 4px;
    }

    /* The spotlight is a hole: positioned precisely, box-shadow dims everything outside */
    .look-spotlight {
      position: absolute;
      border-radius: 3px;
      /* box-shadow creates the dim-outside effect */
      box-shadow: 0 0 0 9999px rgba(28, 25, 23, 0.62);
      z-index: 1;
      /* Actual position set inline per card */
    }

    /* ── Text panel ── */
    .look-panel {
      width: 100%;
      max-width: 560px;
      margin-inline: auto;
      padding-top: var(--space-8);
    }

    /* ── Stage 0 ── */
    .look-0-text {
      font-family: var(--font-display);
      font-size: clamp(var(--text-xl), 3vw, var(--text-2xl));
      line-height: 1.5;
      color: var(--text-invert);
      max-width: 52ch;
      text-align: center;
      margin-inline: auto;
      padding-top: var(--space-8);
    }
    .look-0-btn-wrap {
      display: flex;
      justify-content: center;
      padding-top: var(--space-8);
    }

    /* ── Buttons ── */
    .look-btn {
      font-family: var(--font-body);
      font-size: var(--text-base);
      color: var(--bg-dark);
      background: var(--text-invert);
      border: none;
      border-radius: 3px;
      padding: var(--space-3) var(--space-7);
      cursor: pointer;
      transition: background var(--ease), color var(--ease);
      letter-spacing: 0.01em;
    }
    .look-btn:hover {
      background: var(--accent-dim);
    }
    .look-btn.look-btn-ghost {
      background: transparent;
      border: 1px solid rgba(244,241,236,0.35);
      color: var(--text-invert);
    }
    .look-btn.look-btn-ghost:hover {
      border-color: var(--text-invert);
      background: rgba(244,241,236,0.08);
    }

    /* ── Card anatomy ── */
    .look-tier-tag {
      display: inline-block;
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      padding: 0.15em 0.55em;
      border-radius: 3px;
      margin-bottom: var(--space-4);
    }
    .tier-obs    { color: var(--obs);    background: var(--obs-bg);    }
    .tier-interp { color: var(--interp); background: var(--interp-bg); }
    .tier-cons   { color: var(--cons);   background: var(--cons-bg);   }
    .tier-theory { color: var(--theory); background: var(--theory-bg); }

    .look-invite {
      font-family: var(--font-display);
      font-size: clamp(var(--text-lg), 2.5vw, var(--text-xl));
      line-height: 1.55;
      color: var(--text-invert);
      margin-bottom: var(--space-6);
    }

    .look-try-row {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      margin-bottom: var(--space-6);
    }

    /* Reveal section: hidden until the try beat */
    .look-reveal-section {
      display: none;
      padding-top: var(--space-2);
    }
    .look-reveal-section.is-shown { display: block; }

    .look-reveal-text {
      font-size: var(--text-base);
      line-height: 1.7;
      color: rgba(244,241,236,0.92);
      margin-bottom: var(--space-4);
    }
    .look-why {
      font-size: var(--text-sm);
      font-style: italic;
      color: rgba(244,241,236,0.6);
      margin-bottom: var(--space-6);
      border-left: 2px solid rgba(244,241,236,0.2);
      padding-left: var(--space-4);
    }

    .look-nav-row {
      display: flex;
      align-items: center;
      gap: var(--space-4);
      flex-wrap: wrap;
    }

    .look-card-count {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      color: rgba(244,241,236,0.38);
      letter-spacing: 0.05em;
      margin-left: auto;
    }

    /* ── Stage Final ── */
    .look-final-intro {
      font-family: var(--font-display);
      font-size: clamp(var(--text-lg), 2.5vw, var(--text-xl));
      line-height: 1.55;
      color: var(--text-invert);
      margin-bottom: var(--space-6);
    }

    .look-reveals-list {
      display: none;
      margin-top: var(--space-8);
    }
    .look-reveals-list.is-shown { display: block; }

    .look-reveal-item {
      margin-bottom: var(--space-8);
      padding-bottom: var(--space-8);
      border-bottom: 1px solid rgba(244,241,236,0.1);
    }
    .look-reveal-item:last-child { border-bottom: none; }

    .look-reveal-label {
      font-family: var(--font-mono);
      font-size: var(--text-xs);
      font-weight: 600;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      color: rgba(244,241,236,0.45);
      margin-bottom: var(--space-3);
    }

    .look-reveal-body {
      font-size: var(--text-base);
      line-height: 1.7;
      color: rgba(244,241,236,0.88);
    }

    .look-credit {
      font-size: var(--text-xs);
      color: rgba(244,241,236,0.32);
      letter-spacing: 0.02em;
      margin-top: var(--space-3);
      text-align: center;
    }

    .look-close {
      font-family: var(--font-display);
      font-size: clamp(var(--text-lg), 2.5vw, var(--text-xl));
      line-height: 1.55;
      color: var(--text-invert);
      margin-top: var(--space-8);
      padding-top: var(--space-8);
      border-top: 1px solid rgba(244,241,236,0.12);
    }

    /* ── Responsive ── */
    @media (min-width: 768px) {
      .look-stage {
        flex-direction: row;
        align-items: flex-start;
        justify-content: center;
        gap: var(--space-12);
        padding: var(--space-16) var(--space-8);
      }
      .look-image-wrap {
        max-width: 460px;
        flex-shrink: 0;
        position: sticky;
        top: var(--space-8);
      }
      .look-panel {
        padding-top: 0;
        max-width: 420px;
      }
      .look-stage[data-stage="0"] {
        flex-direction: column;
        align-items: center;
      }
      .look-stage[data-stage="0"] .look-image-wrap {
        position: static;
        max-width: 520px;
      }
    }
  </style>
</head>
<body>
  <div class="look-shell">

    <a href="/" class="look-back" aria-label="Back to Grammar of Things">← Grammar of Things</a>

    <!-- ─── Stage 0: bare object ──────────────────────────────────── -->
    <section class="look-stage is-active" data-stage="0" aria-label="Stage 0">
      <div class="look-image-wrap">
        <img
          src="/images/bowl-interior.jpg"
          alt="Mimbres bowl A326247, interior view"
          width="640" height="529"
        />
      </div>
      <p class="look-0-text">{STAGE_0_TEXT}</p>
      <div class="look-0-btn-wrap">
        <button class="look-btn" data-action="start">
          {STAGE_0_BUTTON}
        </button>
      </div>
    </section>

    <!-- ─── Cards 1–6 ────────────────────────────────────────────── -->
    {BOWL_CARDS.map((card, i) => (
      <section class="look-stage" data-stage={`card-${i}`} aria-label={`Card ${i + 1}`}>
        <div class="look-image-wrap">
          <img
            class="look-card-img"
            src={`/images/bowl-${card.image}.jpg`}
            alt={`Mimbres bowl A326247, ${card.image} view`}
            width={card.image === "interior" ? 640 : 640}
            height={card.image === "interior" ? 529 : 431}
            data-interior-src="/images/bowl-interior.jpg"
            data-interior-h="529"
            data-exterior-src="/images/bowl-exterior.jpg"
            data-exterior-h="431"
            data-reveal-image={card.revealImage ?? card.image}
          />
          <div class="look-overlay" aria-hidden="true">
            <div class="look-spotlight"
              data-region={JSON.stringify(card.region)}
              data-reveal-region={JSON.stringify(card.revealRegion ?? card.region)}
            ></div>
          </div>
        </div>

        <div class="look-panel">
          <span class={`look-tier-tag ${TIER_CLASSES[card.tier]}`}>
            {TIER_LABELS[card.tier]}
          </span>

          <p class="look-invite">{card.invite}</p>

          <div class="look-try-row">
            <button class="look-btn look-btn-ghost" data-action="reveal" data-card={i}>
              Show me
            </button>
          </div>

          <div class="look-reveal-section" data-reveal={i}>
            <p class="look-reveal-text">{card.reveal}</p>
            <p class="look-why">{card.why}</p>

            <div class="look-nav-row">
              {i > 0 && (
                <button class="look-btn look-btn-ghost" data-action="prev" data-card={i}>
                  ← Back
                </button>
              )}
              {i < BOWL_CARDS.length - 1 ? (
                <button class="look-btn" data-action="next" data-card={i}>
                  Next →
                </button>
              ) : (
                <button class="look-btn" data-action="final">
                  Now you try →
                </button>
              )}
              <span class="look-card-count">
                {i + 1} / {BOWL_CARDS.length}
              </span>
            </div>
          </div>
        </div>
      </section>
    ))}

    <!-- ─── Stage Final: the pitcher ─────────────────────────────── -->
    <section class="look-stage" data-stage="final" aria-label="Now you try">
      <div class="look-image-wrap">
        <img
          id="pitcher-img"
          src={PITCHER_IMAGE_URL}
          alt="Pitcher, The Metropolitan Museum of Art"
          width="1568"
          height="1568"
          loading="lazy"
          style="max-width:100%; height:auto;"
        />
        <div class="look-overlay" id="pitcher-overlay" aria-hidden="true">
          <div class="look-spotlight" id="pitcher-spotlight"></div>
        </div>
        <p class="look-credit">{PITCHER_CREDIT}</p>
      </div>

      <div class="look-panel">
        <p class="look-final-intro">{STAGE_FINAL_INTRO}</p>

        <button class="look-btn look-btn-ghost" data-action="reveal-all">
          {STAGE_FINAL_BUTTON}
        </button>

        <div class="look-reveals-list" id="reveals-list">
          {PITCHER_REVEALS.map((r) => (
            <div
              class="look-reveal-item"
              data-pitcher-region={JSON.stringify(r.region)}
            >
              <div class="look-reveal-label">{r.label}</div>
              <p class="look-reveal-body">{r.text}</p>
            </div>
          ))}

          <p class="look-close">{STAGE_FINAL_CLOSE}</p>

          <div style="margin-top: var(--space-8);">
            <button class="look-btn look-btn-ghost" data-action="restart">
              ← Start over
            </button>
          </div>
        </div>
      </div>
    </section>

  </div><!-- .look-shell -->

  <script>
    // ── State ──────────────────────────────────────────────────────────────
    // stage: "0" | "card-0" … "card-5" | "final"
    let currentStage = "0";

    function showStage(stage) {
      document.querySelectorAll(".look-stage").forEach(el => {
        el.classList.toggle("is-active", el.dataset.stage === stage);
      });
      currentStage = stage;
      window.scrollTo({ top: 0, behavior: "smooth" });
    }

    // ── Overlay helpers ────────────────────────────────────────────────────
    function positionSpotlight(spotlight, region) {
      spotlight.style.top    = region.top;
      spotlight.style.left   = region.left;
      spotlight.style.width  = region.width;
      spotlight.style.height = region.height;
    }

    function showOverlay(stage, region) {
      const overlay   = stage.querySelector(".look-overlay");
      const spotlight = stage.querySelector(".look-spotlight");
      if (!overlay || !spotlight) return;
      positionSpotlight(spotlight, region);
      overlay.classList.add("is-visible");
    }

    function hideOverlay(stage) {
      const overlay = stage.querySelector(".look-overlay");
      if (overlay) overlay.classList.remove("is-visible");
    }

    // ── Card image swap (Card 4: interior → exterior on reveal) ───────────
    function setCardImage(imgEl, which) {
      const src = imgEl.dataset[which + "Src"];
      const h   = imgEl.dataset[which + "H"];
      if (src && imgEl.src !== src) {
        imgEl.setAttribute("src", src);
        imgEl.setAttribute("height", h);
        imgEl.setAttribute("alt", `Mimbres bowl A326247, ${which} view`);
      }
    }

    // ── Card reveal ────────────────────────────────────────────────────────
    function revealCard(cardIndex) {
      const stage = document.querySelector(`[data-stage="card-${cardIndex}"]`);
      if (!stage) return;

      const revealSection = stage.querySelector(`[data-reveal="${cardIndex}"]`);
      if (!revealSection) return;
      revealSection.classList.add("is-shown");

      // Image swap if needed
      const imgEl      = stage.querySelector(".look-card-img");
      const spotlight  = stage.querySelector(".look-spotlight");
      const revealImg  = imgEl?.dataset.revealImage;

      if (imgEl && revealImg) {
        setCardImage(imgEl, revealImg);
      }

      // Spotlight on reveal region
      if (spotlight) {
        try {
          const region = JSON.parse(spotlight.dataset.revealRegion);
          showOverlay(stage, region);
        } catch (e) { /* malformed JSON — skip overlay */ }
      }
    }

    // ── Pitcher reveal-all ─────────────────────────────────────────────────
    function revealAll() {
      const list = document.getElementById("reveals-list");
      if (list) list.classList.add("is-shown");

      // Spotlight the first pitcher reveal
      const firstItem = list?.querySelector("[data-pitcher-region]");
      if (!firstItem) return;
      try {
        const region     = JSON.parse(firstItem.dataset.pitcherRegion);
        const overlay    = document.getElementById("pitcher-overlay");
        const spotlight  = document.getElementById("pitcher-spotlight");
        if (overlay && spotlight) {
          positionSpotlight(spotlight, region);
          overlay.classList.add("is-visible");
        }
      } catch (e) { /* skip */ }
    }

    // ── Hover spotlights on pitcher reveal items ───────────────────────────
    function initPitcherHover() {
      const overlay   = document.getElementById("pitcher-overlay");
      const spotlight = document.getElementById("pitcher-spotlight");
      if (!overlay || !spotlight) return;

      document.querySelectorAll("[data-pitcher-region]").forEach(item => {
        item.addEventListener("mouseenter", () => {
          try {
            const region = JSON.parse(item.dataset.pitcherRegion);
            positionSpotlight(spotlight, region);
            overlay.classList.add("is-visible");
          } catch (e) { /* skip */ }
        });
      });
    }

    // ── Event delegation ───────────────────────────────────────────────────
    document.addEventListener("click", (e) => {
      const btn = e.target.closest("[data-action]");
      if (!btn) return;

      const action = btn.dataset.action;
      const cardIndex = btn.dataset.card !== undefined ? parseInt(btn.dataset.card, 10) : null;

      if (action === "start") {
        showStage("card-0");
        return;
      }

      if (action === "reveal") {
        revealCard(cardIndex);
        return;
      }

      if (action === "next") {
        // Hide overlay before moving
        const stageEl = document.querySelector(`[data-stage="card-${cardIndex}"]`);
        if (stageEl) hideOverlay(stageEl);
        showStage(`card-${cardIndex + 1}`);
        return;
      }

      if (action === "prev") {
        const stageEl = document.querySelector(`[data-stage="card-${cardIndex}"]`);
        if (stageEl) hideOverlay(stageEl);
        if (cardIndex === 0) {
          showStage("0");
        } else {
          // Re-enter the previous card in already-revealed state
          showStage(`card-${cardIndex - 1}`);
          revealCard(cardIndex - 1);
        }
        return;
      }

      if (action === "final") {
        const stageEl = document.querySelector(`[data-stage="card-${BOWL_CARDS_LENGTH - 1}"]`);
        if (stageEl) hideOverlay(stageEl);
        showStage("final");
        return;
      }

      if (action === "reveal-all") {
        revealAll();
        initPitcherHover();
        return;
      }

      if (action === "restart") {
        // Reset all reveal sections and overlays, go back to stage 0
        document.querySelectorAll(".look-reveal-section").forEach(el => el.classList.remove("is-shown"));
        document.querySelectorAll(".look-overlay").forEach(el => el.classList.remove("is-visible"));
        document.querySelectorAll(".look-card-img").forEach(imgEl => {
          setCardImage(imgEl, "interior");
        });
        const list = document.getElementById("reveals-list");
        if (list) list.classList.remove("is-shown");
        showStage("0");
        return;
      }
    });

    // Expose card count to inline script (Astro serializes at build time)
    const BOWL_CARDS_LENGTH = document.querySelectorAll("[data-stage^='card-']").length;
  </script>

</body>
</html>
