---
export const prerender = true;
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Reference Corpus — The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
</head>
<body>
  <SiteNav />

  <div class="ref-page">
    <div class="container">

      <div class="ref-head">
        <h1>Reference Corpus</h1>
        <p class="ref-sub">Authenticated objects that form the statistical baseline for perceptual fingerprint comparison. Each tradition requires at least 30 well-documented pieces before z-score comparison becomes meaningful.</p>
      </div>

      <div id="refLoading" class="ref-loading">Loading reference objects…</div>
      <div id="refEmpty" class="ref-empty" style="display:none">
        <p>No reference objects cataloged yet.</p>
        <p>When cataloging an object, check "Mark as a reference piece for the corpus" to designate authenticated, well-documented pieces. These should be excavated objects from known institutional collections — not objects whose authenticity is under evaluation.</p>
        <a href="/catalog" class="ref-catalog-link">Catalog a reference piece →</a>
      </div>
      <div id="refContent" style="display:none"></div>

    </div>
  </div>

  <SiteFooter />

<script>
import { VECTOR_KEY } from '../db/types';
import { VECTOR_KEY_DISPLAY_NAMES as PRINCIPLE_NAMES } from '../lib/principles';

const TRADITION_LABELS = {
  mimbres: 'Mimbres',
  hohokam: 'Hohokam',
  ancestral_puebloan: 'Ancestral Puebloan',
  casas_grandes: 'Casas Grandes / Paquimé',
  salado: 'Salado',
  other: 'Other',
};
const TARGET = 30;
const STATS_MIN = 5;

async function load() {
  const loading = document.getElementById('refLoading');
  const empty   = document.getElementById('refEmpty');
  const content = document.getElementById('refContent');

  try {
    const [objRes, distRes] = await Promise.all([
      fetch('/api/objects'),
      fetch('/api/reference/distribution'),
    ]);
    if (!objRes.ok) throw new Error(`Objects API ${objRes.status}`);
    const allObjects = await objRes.json();
    const refObjects = allObjects.filter(o => o.is_reference);

    loading.style.display = 'none';

    if (!refObjects.length) {
      empty.style.display = '';
      return;
    }

    let distByTrad = {};
    if (distRes.ok) {
      const distData = await distRes.json();
      for (const t of (distData.traditions ?? [])) {
        distByTrad[t.tradition] = t;
      }
    }

    // Group by tradition
    const byTrad = {};
    for (const obj of refObjects) {
      const trad = obj.reference_tradition ?? 'other';
      if (!byTrad[trad]) byTrad[trad] = [];
      byTrad[trad].push(obj);
    }

    const tradOrder = ['mimbres','hohokam','ancestral_puebloan','casas_grandes','salado','other'];
    const orderedTrads = [
      ...tradOrder.filter(t => byTrad[t]),
      ...Object.keys(byTrad).filter(t => !tradOrder.includes(t)),
    ];

    content.style.display = '';
    content.innerHTML = orderedTrads.map(trad => {
      const objs = byTrad[trad];
      const n = objs.length;
      const pct = Math.min((n / TARGET) * 100, 100);
      const label = TRADITION_LABELS[trad] ?? trad;
      const dist = distByTrad[trad];
      const hasStats = dist && dist.n >= STATS_MIN;

      const thumbnails = objs.map(obj => {
        const imgKey = obj.image_analysis_key?.split(',')[0]?.trim();
        const imgSrc = imgKey ? `/api/image/${imgKey}` : null;
        const displayId = obj.catalog_number ?? `#${obj.id}`;
        return `<a href="/corpus/${obj.id}" class="ref-thumb" title="${displayId}">
          ${imgSrc
            ? `<img src="${imgSrc}" alt="${displayId}" loading="lazy" />`
            : `<span class="ref-thumb-none">No image</span>`}
        </a>`;
      }).join('');

      const statsSection = hasStats
        ? buildMeanBars(dist.principles)
        : `<p class="ref-stats-pending">Fingerprint distribution available when ${STATS_MIN} or more objects are cataloged (${n}/${STATS_MIN} so far).</p>`;

      return `
        <div class="ref-tradition">
          <div class="ref-trad-head">
            <div class="ref-trad-title-row">
              <h2 class="ref-trad-title">${label}</h2>
              <span class="ref-trad-count">${n} object${n !== 1 ? 's' : ''}</span>
            </div>
            <div class="ref-progress-track">
              <div class="ref-progress-fill" style="width:${pct.toFixed(1)}%"></div>
            </div>
            <p class="ref-progress-label">${n} / ${TARGET} authenticated pieces for baseline</p>
          </div>
          <div class="ref-thumbs">${thumbnails}</div>
          <div class="ref-stats">${statsSection}</div>
        </div>`;
    }).join('');

  } catch (err) {
    loading.textContent = `Error: ${err.message}`;
  }
}

function buildMeanBars(principles) {
  const rows = principles.map(p => {
    const name = PRINCIPLE_NAMES[p.key] ?? p.key;
    const pct = (p.mean / 3) * 100;
    const color = p.key.startsWith('ap') ? 'var(--accent)' : 'var(--cons)';
    return `<div class="mean-bar-row">
      <span class="mean-code">${p.key}</span>
      <div class="mean-track"><div class="mean-fill" style="width:${pct.toFixed(1)}%;background:${color}"></div></div>
      <span class="mean-val">${p.mean.toFixed(2)}</span>
      <span class="mean-sd">±${p.stddev.toFixed(2)}</span>
      <span class="mean-name">${name}</span>
    </div>`;
  }).join('');
  return `<div class="mean-bars-wrap">
    <p class="mean-bars-label">Mean fingerprint scores (0–3) across ${principles.length > 0 ? 'reference objects' : 'objects'}</p>
    <div class="mean-bars">${rows}</div>
  </div>`;
}

load();
</script>

<style>
  .ref-page {
    padding-block: var(--space-16) var(--space-24);
    background: var(--bg);
    min-height: 80vh;
  }

  .ref-head { margin-bottom: var(--space-12); }
  h1 { font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl)); margin-bottom: var(--space-4); letter-spacing: var(--tracking-snug); }
  .ref-sub { font-size: var(--text-base); color: var(--text-muted); line-height: var(--leading-body); max-width: 68ch; }

  .ref-loading, .ref-empty {
    font-size: var(--text-base); color: var(--text-muted);
    padding: var(--space-16) 0; max-width: none;
  }
  .ref-empty p { margin-bottom: var(--space-4); line-height: var(--leading-body); max-width: 56ch; }
  .ref-catalog-link {
    display: inline-block; margin-top: var(--space-2);
    font-family: var(--font-mono); font-size: var(--text-sm);
    color: var(--accent); text-decoration: none;
    border: 1px solid var(--accent); padding: var(--space-2) var(--space-5);
    border-radius: var(--radius-sm);
  }
  .ref-catalog-link:hover { background: var(--accent-dim); }

  /* Tradition section */
  .ref-tradition {
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    margin-bottom: var(--space-10);
    background: var(--bg-surface);
  }

  .ref-trad-head { margin-bottom: var(--space-6); }
  .ref-trad-title-row { display: flex; align-items: baseline; gap: var(--space-4); margin-bottom: var(--space-3); }
  h2.ref-trad-title {
    font-size: var(--text-xl); font-family: var(--font-display);
    font-weight: normal; letter-spacing: var(--tracking-snug);
  }
  .ref-trad-count {
    font-family: var(--font-mono); font-size: var(--text-xs);
    color: var(--cons); background: var(--cons-bg);
    padding: 0.1em 0.6em; border-radius: var(--radius-xs);
    letter-spacing: var(--tracking-wide);
  }

  /* Progress bar */
  .ref-progress-track {
    height: 6px; background: var(--bg-alt);
    border-radius: var(--radius-xs); overflow: hidden;
    margin-bottom: var(--space-2);
  }
  .ref-progress-fill { height: 100%; background: var(--cons); border-radius: var(--radius-xs); transition: width 0.4s var(--ease); }
  .ref-progress-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); max-width: none; }

  /* Thumbnails */
  .ref-thumbs {
    display: flex; flex-wrap: wrap; gap: var(--space-3);
    margin-bottom: var(--space-8);
  }
  .ref-thumb {
    display: block; width: 88px; height: 88px;
    border-radius: var(--radius-sm); overflow: hidden;
    border: 1px solid var(--border); background: var(--bg-alt);
    transition: border-color var(--ease);
    text-decoration: none;
  }
  .ref-thumb:hover { border-color: var(--cons); }
  .ref-thumb img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .ref-thumb-none {
    width: 100%; height: 100%; display: flex; align-items: center; justify-content: center;
    font-size: 0.6rem; color: var(--text-muted); font-family: var(--font-mono);
  }

  /* Stats */
  .ref-stats-pending {
    font-size: var(--text-sm); color: var(--text-muted);
    font-style: italic; max-width: 56ch; line-height: var(--leading-body);
  }

  .mean-bars-wrap { background: var(--bg); border: 1px solid var(--border); border-radius: var(--radius-sm); padding: var(--space-5) var(--space-6); }
  .mean-bars-label {
    font-family: var(--font-mono); font-size: var(--text-xs);
    color: var(--text-muted); letter-spacing: var(--tracking-wide); text-transform: uppercase;
    margin-bottom: var(--space-4); max-width: none;
  }
  .mean-bars { display: flex; flex-direction: column; gap: var(--space-1); }
  .mean-bar-row {
    display: grid;
    grid-template-columns: 42px 80px 32px 36px 1fr;
    gap: var(--space-2); align-items: center;
  }
  .mean-code { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); }
  .mean-track { height: 5px; background: var(--bg-alt); border-radius: var(--radius-xs); overflow: hidden; }
  .mean-fill { height: 100%; border-radius: var(--radius-xs); }
  .mean-val { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text); text-align: right; }
  .mean-sd  { font-family: var(--font-mono); font-size: 0.6rem; color: var(--text-muted); }
  .mean-name { font-size: 0.7rem; color: var(--text-muted); }

  @media (max-width: 640px) {
    .ref-tradition { padding: var(--space-5); }
    .mean-bar-row { grid-template-columns: 38px 60px 28px 32px 1fr; }
  }
</style>
</body>
</html>
