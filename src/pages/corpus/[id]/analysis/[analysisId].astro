---
export const prerender = false;
import { env as cfEnv } from 'cloudflare:workers';
import { renderMarkdown, readTime } from '../../../../lib/markdown';
import { isAdmin } from '../../../../lib/auth';
import { VECTOR_KEY } from '../../../../db/types';
import { VECTOR_KEY_DISPLAY_NAMES as PRINCIPLE_NAMES } from '../../../../lib/principles';
import SiteNav from '../../../../components/SiteNav.astro';
import SiteFooter from '../../../../components/SiteFooter.astro';

const { id, analysisId } = Astro.params;
const admin = await isAdmin(Astro.request);
const env = cfEnv as unknown as Record<string, any>;
const db  = env.DB;

let analysis: any = null;
let object: any   = null;
let notFound      = false;

if (!db || !id || !analysisId) {
  notFound = true;
} else {
  analysis = await db
    .prepare('SELECT * FROM analyses WHERE id = ? AND object_id = ?')
    .bind(Number(analysisId), Number(id))
    .first();
  if (!analysis) {
    notFound = true;
  } else {
    object = await db.prepare('SELECT * FROM objects WHERE id = ?').bind(Number(id)).first();
  }
}

let canonical: any = null;
if (object?.doc_canonical) { try { canonical = JSON.parse(object.doc_canonical); } catch {} }

let fingerprintFlag: any = null;
if (analysis?.fingerprint_flag) { try { fingerprintFlag = JSON.parse(analysis.fingerprint_flag); } catch {} }

let provenanceFlags: any[] = [];
if (analysis?.provenance_flags) { try { provenanceFlags = JSON.parse(analysis.provenance_flags); } catch {} }

let contradictionFlags: any[] = [];
if (analysis?.contradiction_flags) { try { contradictionFlags = JSON.parse(analysis.contradiction_flags); } catch {} }

const ALIGNMENT_TOOLTIPS: Record<string, string> = {
  aligned:      'Fingerprint scores are perceptually consistent with the claimed tradition',
  inconclusive: 'Insufficient signal to draw a conclusion — the default for most objects',
  divergent:    'At least two scores warrant closer human examination',
};
const STRENGTH_TOOLTIPS: Record<string, string> = {
  none:     'Nothing flagged for follow-up',
  weak:     'Minor signals worth noting',
  moderate: 'More notable signals',
  strong:   'Significant flags — close examination recommended',
};

function scoreColor(s: number) {
  return s === 0 ? '#d4cdc4' : s === 1 ? '#c8a882' : s === 2 ? '#c4742a' : '#9b4f19';
}

const vec: number[] = analysis?.analysis_vector ? JSON.parse(analysis.analysis_vector) : [];
const imgKeys = object?.image_analysis_key?.split(',').map((k: string) => k.trim()).filter(Boolean) ?? [];
const accession = object?.catalog_number ?? object?.accession_number ?? `Object ${id}`;
const date = analysis ? new Date(analysis.created_at).toLocaleString('en-US', {
  month: 'long', day: 'numeric', year: 'numeric',
  hour: 'numeric', minute: '2-digit',
  timeZone: 'America/Los_Angeles',
  timeZoneName: 'short',
}) : '';
const totalWords = [analysis?.pass1_text, analysis?.pass2_text, analysis?.pass3_text].filter(Boolean).join(' ');
const readMin = readTime(totalWords);
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{notFound ? 'Not found' : `Analysis — ${accession}`} · The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
  <style is:global>
    @media print {
      nav, footer { display: none !important; }
    }
  </style>
</head>
<body>
  <SiteNav />

  <div class="page">
    <div class="container">

      {notFound ? (
        <p class="not-found">Analysis not found.</p>
      ) : (
        <>
          <div class="top-bar">
            <a href={`/corpus/${id}`} class="back-link">← {accession}</a>
            <div class="top-bar-right">
              <a href={`/api/analysis/${analysisId}?format=md`} download class="download-link">↓ .md</a>
              <button id="print-btn" class="download-link">↓ PDF</button>
            </div>
          </div>

          <header class="analysis-header">
            <div class="header-images">
              {imgKeys.slice(0, 2).map((key: string, i: number) => (
                <img src={`/api/image/${key}`} alt={`View ${i + 1}`} />
              ))}
            </div>
            <div class="header-info">
              <p class="eyebrow">{analysis.mode} · {analysis.audience}</p>
              <h1>{accession}</h1>
              <p class="date">{date} · Analysis #{analysisId}{readMin > 0 ? ` · ${readMin} min read` : ''}</p>
              {analysis.model_pass2 && <p class="model">Model: {analysis.model_pass2}</p>}

              {object && (
                <dl class="meta">
                  {object.attribution_culture && <div><dt>Culture</dt><dd>{object.attribution_culture}</dd></div>}
                  {canonical?.period           && <div><dt>Period</dt><dd>{canonical.period}</dd></div>}
                  {object.source_institution   && <div><dt>Institution</dt><dd>{object.source_institution}</dd></div>}
                </dl>
              )}

              {fingerprintFlag && (
                <div class={`fp-flag flag-${fingerprintFlag.alignment}`}>
                  <span class="flag-badge" data-tooltip={ALIGNMENT_TOOLTIPS[fingerprintFlag.alignment]}>{fingerprintFlag.alignment}</span>
                  <span class="flag-strength" data-tooltip={STRENGTH_TOOLTIPS[fingerprintFlag.flag_strength]}>{fingerprintFlag.flag_strength}</span>
                  <p class="flag-reason">{fingerprintFlag.reasoning}</p>
                </div>
              )}
            </div>
          </header>

          {/* Pass 1 */}
          {analysis.pass1_text && (
            <details class="pass-section pass-collapsible" id="pass1-section">
              <summary class="pass-label">
                <span class="pass-num">Pass 1</span>
                <span class="pass-name">Blind observation</span>
                <span class="pass-note">Documentation excluded — image only</span>
                <span class="pass-toggle" aria-hidden="true"></span>
              </summary>
              <div class="pass-body prose" set:html={renderMarkdown(analysis.pass1_text)} />
            </details>
          )}

          {/* Fingerprint */}
          {vec.length > 0 && (
            <details class="pass-section pass-collapsible" id="fingerprint-section">
              <summary class="pass-label">
                <span class="pass-num">Fingerprint</span>
                <span class="pass-name">{VECTOR_KEY.length}-principle perceptual vector</span>
                <span class="pass-toggle" aria-hidden="true"></span>
              </summary>
              <div class="fp-grid">
                {VECTOR_KEY.map((k, i) => {
                  const s = vec[i] ?? 0;
                  return (
                    <div class="fp-row">
                      <span class="fp-code">{k}</span>
                      <div class="fp-track"><div class="fp-fill" style={`width:${(s/3)*100}%;background:${scoreColor(s)}`}></div></div>
                      <span class="fp-score">{s}</span>
                      <a class="fp-name" href={`/principles#${k}`}>{PRINCIPLE_NAMES[k] ?? k}</a>
                    </div>
                  );
                })}
              </div>
            </details>
          )}

          {/* Pass 2 */}
          {analysis.pass2_text && (
            <section class="pass-section" id="pass2-section">
              <div class="pass-label">
                <span class="pass-num">Pass 2</span>
                <span class="pass-name">{analysis.mode === 'connections' ? 'Cultural connections' : 'Artifact analysis'}</span>
              </div>
              {analysis.pass2_truncated ? (
                <p class="truncated-note">This analysis reached the output limit and may be cut short. Re-run analysis for a complete result.</p>
              ) : null}
              <div class="pass2-layout">
                <div class="pass-body prose" id="pass2-body" set:html={renderMarkdown(analysis.pass2_text)} />
                <nav class="toc-rail" id="toc-rail" aria-label="Document outline">
                  <p class="toc-heading">Contents</p>
                  <ol class="toc-list" id="toc-list"></ol>
                </nav>
              </div>
            </section>
          )}

          {/* Pass 3 */}
          {analysis.pass3_text && (
            <section class="pass-section">
              <div class="pass-label">
                <span class="pass-num">Pass 3</span>
                <span class="pass-name">What to take forward</span>
              </div>
              {analysis.pass3_truncated ? (
                <p class="truncated-note">This section reached the output limit and may be cut short. Re-run analysis for a complete result.</p>
              ) : null}
              <div class="pass-body prose" set:html={renderMarkdown(analysis.pass3_text)} />
            </section>
          )}

          {/* Provenance assessment */}
          {provenanceFlags.length > 0 && (
            <section class="pass-section auth-section">
              <div class="pass-label">
                <span class="pass-num">Provenance</span>
                <span class="pass-name">Integrity assessment</span>
                <span class="pass-note">Documentation gaps and structural anomalies</span>
              </div>
              <div class="auth-flags">
                {provenanceFlags.map((f: any) => (
                  <div class={`auth-flag sev-${f.severity}`}>
                    <div class="auth-flag-head">
                      <span class="auth-flag-code">{f.flag}</span>
                      <span class={`auth-sev-badge sev-badge-${f.severity}`}>{f.severity}</span>
                    </div>
                    <p class="auth-flag-detail">{f.detail}</p>
                  </div>
                ))}
              </div>
            </section>
          )}

          {/* Contradiction detection */}
          {contradictionFlags.length > 0 && (
            <section class="pass-section auth-section">
              <div class="pass-label">
                <span class="pass-num">Contradictions</span>
                <span class="pass-name">Documentation vs. observation</span>
                <span class="pass-note">Claims in tension with blind Pass 1 findings</span>
              </div>
              <div class="auth-flags">
                {contradictionFlags.map((f: any) => (
                  <div class={`auth-flag sev-${f.severity}`}>
                    <div class="auth-flag-head">
                      <span class={`auth-sev-badge sev-badge-${f.severity}`}>{f.severity}</span>
                    </div>
                    <div class="contra-grid">
                      <div class="contra-row">
                        <span class="contra-label">Claim</span>
                        <p class="contra-text">{f.claim}</p>
                      </div>
                      <div class="contra-row">
                        <span class="contra-label">Observed</span>
                        <p class="contra-text">{f.observation}</p>
                      </div>
                      <div class="contra-row contra-tension">
                        <span class="contra-label">Tension</span>
                        <p class="contra-text">{f.contradiction}</p>
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </section>
          )}
          {admin && (
            <section class="notes-section">
              <div class="pass-label">
                <span class="pass-num">Notes</span>
                <span class="pass-name">Admin only — never shown publicly</span>
              </div>
              <textarea id="analysisNotes" class="notes-textarea" rows="4" placeholder="Pass 2 missed coiling construction, re-run after library update…">{analysis.notes ?? ''}</textarea>
              <div class="notes-footer">
                <button id="saveNotesBtn" class="save-notes-btn">Save note</button>
                <span id="notesSaveStatus" class="notes-status"></span>
              </div>
            </section>
          )}
        </>
      )}
    </div>
  </div>

  <SiteFooter />
</body>
</html>

<script define:vars={{ analysisId, isAdmin: admin }}>
// Build Pass 2 TOC
(function () {
  const body = document.getElementById('pass2-body');
  const list = document.getElementById('toc-list');
  if (!body || !list) return;

  const headings = body.querySelectorAll('h2, h3');
  if (headings.length === 0) {
    document.getElementById('toc-rail').style.display = 'none';
    return;
  }

  headings.forEach(function (h, i) {
    const slug = 'p2-' + i + '-' + h.textContent.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/-+$/, '').slice(0, 48);
    h.id = slug;
    const li = document.createElement('li');
    li.className = h.tagName === 'H3' ? 'toc-h3' : 'toc-h2';
    const a = document.createElement('a');
    a.href = '#' + slug;
    a.textContent = h.textContent;
    li.appendChild(a);
    list.appendChild(li);
  });

  const links = list.querySelectorAll('a');
  const observer = new IntersectionObserver(
    function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        const target = list.querySelector('a[href="#' + entry.target.id + '"]');
        if (!target) return;
        links.forEach(function (l) { l.classList.remove('toc-active'); });
        target.classList.add('toc-active');
      });
    },
    { rootMargin: '-8% 0% -80% 0%', threshold: 0 }
  );

  headings.forEach(function (h) { observer.observe(h); });
})();

document.getElementById('print-btn')?.addEventListener('click', () => window.print());

if (isAdmin) {
  document.getElementById('saveNotesBtn')?.addEventListener('click', async () => {
    const btn    = document.getElementById('saveNotesBtn');
    const status = document.getElementById('notesSaveStatus');
    const text   = document.getElementById('analysisNotes').value;
    btn.disabled = true;
    btn.textContent = 'Saving…';
    status.textContent = '';
    try {
      const res = await fetch(`/api/analysis/${analysisId}`, {
        method: 'PATCH',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ notes: text }),
      });
      if (res.ok) {
        status.textContent = 'Saved';
        status.className = 'notes-status notes-saved';
      } else {
        status.textContent = 'Error saving';
        status.className = 'notes-status notes-error';
      }
    } catch {
      status.textContent = 'Error saving';
      status.className = 'notes-status notes-error';
    } finally {
      btn.disabled = false;
      btn.textContent = 'Save note';
    }
  });
}
</script>

<style>
  .page { padding-block: var(--space-16) var(--space-24); background: var(--bg); }
  .container { max-width: 860px; }
  .not-found { color: var(--text-muted); padding: var(--space-16) 0; }

  .top-bar { display: flex; justify-content: space-between; align-items: center; margin-bottom: var(--space-8); }
  .top-bar-right { display: flex; gap: var(--space-2); align-items: center; }
  .back-link { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); text-decoration: none; letter-spacing: var(--tracking-wide); }
  .back-link:hover { color: var(--accent); }
  .download-link {
    font-family: var(--font-mono); font-size: var(--text-xs); color: var(--accent);
    text-decoration: none; border: 1px solid var(--accent);
    padding: var(--space-1) var(--space-4); border-radius: var(--radius-xs); letter-spacing: var(--tracking-wide);
    background: transparent; cursor: pointer;
  }
  .download-link:hover { background: var(--accent-dim); }

  /* Header */
  .analysis-header {
    display: grid; grid-template-columns: 200px 1fr; gap: var(--space-12);
    align-items: start; margin-bottom: var(--space-16);
    padding-bottom: var(--space-12); border-bottom: 2px solid var(--border-strong);
  }
  .header-images { display: flex; flex-direction: column; gap: var(--space-3); }
  .header-info { padding-left: var(--space-4); }
  .header-images img { width: 100%; aspect-ratio: 1; object-fit: cover; object-position: center top; border: 1px solid var(--border); border-radius: var(--radius-sm); display: block; }
  .eyebrow { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--accent); letter-spacing: var(--tracking-wider); text-transform: uppercase; margin-bottom: var(--space-2); max-width: none; }
  h1 { font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl)); letter-spacing: var(--tracking-snug); margin-bottom: var(--space-2); }
  .date, .model { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin-bottom: var(--space-1); max-width: none; }
  .meta { display: flex; flex-direction: column; gap: var(--space-1); margin-top: var(--space-4); margin-bottom: var(--space-4); }
  .meta div { display: grid; grid-template-columns: 80px 1fr; gap: var(--space-3); font-size: var(--text-sm); padding-block: 2px; border-bottom: 1px solid var(--bg-alt); }
  dt { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); padding-top: 2px; }
  dd { color: var(--text); }

  /* Fingerprint flag */
  .fp-flag { padding: var(--space-4); border-radius: var(--radius-sm); border: 1px solid var(--border); margin-top: var(--space-4); }
  .flag-aligned   { background: var(--cons-bg); }
  .flag-divergent { background: var(--theory-bg); }
  .flag-inconclusive { background: var(--bg-alt); }
  .flag-badge { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: var(--tracking-wide); padding: 0.1em 0.5em; border-radius: var(--radius-xs); margin-right: var(--space-2); }
  .flag-aligned   .flag-badge { background: var(--cons-bg);   color: var(--cons); }
  .flag-divergent .flag-badge { background: var(--theory-bg); color: var(--theory); }
  .flag-inconclusive .flag-badge { background: var(--bg-alt); color: var(--text-muted); }
  .flag-strength { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .flag-reason { font-size: var(--text-sm); color: var(--text); line-height: var(--leading-normal); margin-top: var(--space-2); max-width: 60ch; }

  /* Pass sections */
  .pass-section { margin-bottom: var(--space-16); padding-bottom: var(--space-12); border-bottom: 1px solid var(--border); }
  .pass-label { display: flex; align-items: baseline; gap: var(--space-4); flex-wrap: wrap; margin-bottom: var(--space-8); }
  .pass-num  { font-family: var(--font-mono); font-size: var(--text-sm); font-weight: var(--weight-bold); color: var(--accent); letter-spacing: var(--tracking-wide); text-transform: uppercase; }
  .pass-name { font-family: var(--font-display); font-size: var(--text-xl); color: var(--text); }
  .pass-note { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin-left: auto; }

  /* Collapsible pass sections (Pass 1, Fingerprint) */
  .pass-collapsible:not([open]) > :not(summary) { display: none; }
  .pass-collapsible > summary.pass-label { cursor: pointer; list-style: none; }
  .pass-collapsible > summary.pass-label::-webkit-details-marker { display: none; }
  .pass-toggle { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); margin-left: var(--space-4); }
  .pass-toggle::before { content: '+ show'; }
  .pass-collapsible[open] .pass-toggle::before { content: '− hide'; }
  .pass-body { max-width: 74ch; }
  .pass-body :global(p)  { font-size: var(--text-lg); line-height: var(--leading-loose); color: var(--text); margin-bottom: 1em; }
  .pass-body :global(h1),
  .pass-body :global(h2),
  .pass-body :global(h3) { font-family: var(--font-display); color: var(--text); margin: 1.5em 0 0.4em; line-height: 1.3; }
  .pass-body :global(h2) { font-size: var(--text-xl); }
  .pass-body :global(h3) { font-size: var(--text-lg); }
  .pass-body :global(ul),
  .pass-body :global(ol) { padding-left: 1.5em; margin-bottom: 1em; }
  .pass-body :global(li) { font-size: var(--text-lg); line-height: var(--leading-relaxed); color: var(--text); margin-bottom: 0.25em; }
  .pass-body :global(blockquote) { border-left: 3px solid var(--border-strong); padding-left: 1em; color: var(--text-muted); margin: 1em 0; }

  /* Fingerprint bars */
  .fp-grid { background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-md); padding: var(--space-6); display: flex; flex-direction: column; gap: var(--space-2); }
  .fp-row { display: grid; grid-template-columns: 44px 80px 22px 1fr; gap: var(--space-3); align-items: center; padding-block: var(--space-2); border-bottom: 1px solid var(--bg-alt); }
  .fp-row:last-child { border-bottom: none; }
  .fp-code  { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); }
  .fp-track { height: 7px; background: var(--bg-alt); border-radius: var(--radius-xs); overflow: hidden; }
  .fp-fill  { height: 100%; border-radius: var(--radius-xs); }
  .fp-score { font-family: var(--font-mono); font-size: var(--text-xs); font-weight: var(--weight-bold); color: var(--text); text-align: center; }
  .fp-name  { font-size: var(--text-sm); color: var(--text); text-decoration: none; }
  .fp-name:hover { color: var(--accent); text-decoration: underline; text-decoration-thickness: 1px; }

  /* Authenticity flag sections */
  .auth-section {}
  .auth-flags { display: flex; flex-direction: column; gap: var(--space-3); }
  .auth-flag {
    border-left: 3px solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--space-4) var(--space-5);
    background: var(--bg-surface);
  }
  .auth-flag.sev-high   { border-left-color: var(--theory); background: var(--theory-bg); }
  .auth-flag.sev-medium { border-left-color: var(--color-warn); background: var(--color-warn-bg); }
  .auth-flag.sev-low    { border-left-color: var(--border); background: var(--bg-surface); }

  .auth-flag-head { display: flex; align-items: center; gap: var(--space-3); margin-bottom: var(--space-2); }
  .auth-flag-code {
    font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted);
    letter-spacing: var(--tracking-wide);
  }
  .auth-sev-badge {
    font-family: var(--font-mono); font-size: var(--text-xs); font-weight: var(--weight-bold);
    text-transform: uppercase; letter-spacing: var(--tracking-wide);
    padding: 0.1em 0.5em; border-radius: var(--radius-xs);
  }
  .sev-badge-high   { background: var(--theory-bg); color: var(--theory); }
  .sev-badge-medium { background: var(--color-warn-bg); color: var(--text-muted); }
  .sev-badge-low    { background: var(--bg-alt); color: var(--text-muted); }

  .auth-flag-detail { font-size: var(--text-sm); color: var(--text); line-height: var(--leading-body); max-width: 68ch; }

  .contra-grid { display: flex; flex-direction: column; gap: var(--space-2); }
  .contra-row { display: grid; grid-template-columns: 72px 1fr; gap: var(--space-4); align-items: baseline; }
  .contra-label { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); letter-spacing: var(--tracking-wide); padding-top: 2px; }
  .contra-text { font-size: var(--text-sm); color: var(--text); line-height: var(--leading-body); max-width: none; }
  .contra-tension .contra-text { color: var(--theory); font-style: italic; }

  /* Pass 2 two-column layout */
  .pass2-layout {
    display: grid;
    grid-template-columns: minmax(0, 1fr) 196px;
    gap: var(--space-8);
    align-items: start;
  }

  .toc-rail {
    position: sticky;
    top: var(--space-8);
    max-height: calc(100vh - var(--space-16));
    overflow-y: auto;
    padding-left: var(--space-5);
    border-left: 1px solid var(--border);
  }

  .toc-heading {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: var(--tracking-wider);
    margin-bottom: var(--space-3);
  }

  .toc-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .toc-list li a {
