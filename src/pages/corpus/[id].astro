---
export const prerender = false;
import { env as cfEnv } from 'cloudflare:workers';
import { renderMarkdown } from '../../lib/markdown';
import { isAdmin } from '../../lib/auth';
import SiteNav from '../../components/SiteNav.astro';
import SiteFooter from '../../components/SiteFooter.astro';

const { id } = Astro.params;
const admin = await isAdmin(Astro.request);
const env = cfEnv as unknown as Record<string, any>;
const db  = env.DB;

let object: any   = null;
let analyses: any[] = [];
let notFound      = false;

if (!db) {
  notFound = true;
} else {
  const numId = Number(id);
  if (!numId || isNaN(numId)) {
    notFound = true;
  } else {
    object = await db.prepare('SELECT * FROM objects WHERE id = ?').bind(numId).first();
    if (!object) {
      notFound = true;
    } else {
      const r = await db.prepare(
        'SELECT * FROM analyses WHERE object_id = ? ORDER BY created_at DESC LIMIT 20'
      ).bind(numId).all();
      analyses = r.results ?? [];
    }
  }
}

const ALIGNMENT_TOOLTIPS: Record<string, string> = {
  aligned:      'Fingerprint scores are perceptually consistent with the claimed tradition',
  inconclusive: 'Insufficient signal to draw a conclusion — the default for most objects',
  divergent:    'At least two scores warrant closer human examination',
};
const STRENGTH_TOOLTIPS: Record<string, string> = {
  none:     'Nothing flagged for follow-up',
  weak:     'Minor signals worth noting',
  moderate: 'More notable signals',
  strong:   'Significant flags — close examination recommended',
};

// Fetch cross-source claims
let claims: any[] = [];
if (db && object) {
  try {
    const cr = await db.prepare(
      'SELECT id, source_institution, source_url, attribution_culture, created_at FROM object_claims WHERE object_id = ? ORDER BY created_at ASC'
    ).bind(Number(id)).all();
    claims = cr.results ?? [];
  } catch { /* object_claims may not exist if migration hasn't run */ }
}

// Parse doc_canonical for display
let canonical: any = null;
if (object?.doc_canonical) {
  try { canonical = JSON.parse(object.doc_canonical); } catch {}
}

// First analysis image key
const firstImgKey = object?.image_analysis_key?.split(',')[0]?.trim() ?? null;
const imgKeys = object?.image_analysis_key?.split(',').map((k: string) => k.trim()).filter(Boolean) ?? [];

// Parse fingerprint vector
const fpVec: number[] = object?.fingerprint_vector ? JSON.parse(object.fingerprint_vector) : [];

const VECTOR_KEY = [
  'ap_1','ap_2','ap_3','ap_4','ap_5','ap_6','ap_7','ap_8','ap_9','ap_10',
  'ap_11','ap_12','ap_13','ap_14','ap_15',
  'ta_1','ta_2','ta_4','ta_5','ta_13','ta_15','ta_20','ta_28',
  'ta_47','ta_48','ta_49','ta_51',
];
const PRINCIPLE_NAMES: Record<string, string> = {
  ap_1:'Production Trace Reading', ap_2:'Sequence Inference', ap_3:'Material Boundary Attention',
  ap_4:'Wear Differential', ap_5:'Absence as Evidence', ap_6:'Composite Detection',
  ap_7:'Anatomical Correspondence', ap_8:'Symmetry as Evidence', ap_9:'Proportion as Encoding',
  ap_10:'Color Zone Logic', ap_11:'Investment Gradient', ap_12:'Attachment Point Reading',
  ap_13:'Orientation Dependency', ap_14:'Completion State', ap_15:'Reduction vs. Construction',
  ta_1:'Edge Detection', ta_2:'Color Opponent Channels', ta_4:'Figure-Ground Relationships',
  ta_5:'Grouping', ta_13:'Overlap / Occlusion', ta_15:'Closure / Negative Space',
  ta_20:'Simultaneous Contrast', ta_28:'Specularity / Reflection',
  ta_47:'Face Detection', ta_48:'Biological Motion', ta_49:'Gaze Direction', ta_51:'Visual Pop-out',
};

function scoreColor(s: number) {
  return s === 0 ? '#d4cdc4' : s === 1 ? '#c8a882' : s === 2 ? '#c4742a' : '#9b4f19';
}

function buildRadar(vec: number[]): string {
  const cx = 200, cy = 200, r = 155, n = VECTOR_KEY.length;
  const toRad = (d: number) => (d * Math.PI) / 180;
  const spoke = (i: number, radius: number) => {
    const a = toRad((360 / n) * i - 90);
    return { x: cx + radius * Math.cos(a), y: cy + radius * Math.sin(a) };
  };
  const ring = (frac: number) =>
    VECTOR_KEY.map((_, i) => spoke(i, r * frac))
      .map((p, i) => `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`).join(' ') + ' Z';
  const poly = VECTOR_KEY.map((_, i) => {
    const s = vec[i] ?? 0;
    const p = spoke(i, s === 0 ? 4 : r * (s / 3));
    return `${i === 0 ? 'M' : 'L'}${p.x.toFixed(1)},${p.y.toFixed(1)}`;
  }).join(' ') + ' Z';
  const spokes = VECTOR_KEY.map((_, i) => {
    const o = spoke(i, r);
    return `<line x1="${cx}" y1="${cy}" x2="${o.x.toFixed(1)}" y2="${o.y.toFixed(1)}" stroke="#d4cdc4" stroke-width="1"/>`;
  }).join('');
  const labels = VECTOR_KEY.map((k, i) => {
    const pos = spoke(i, r + 20);
    const anchor = pos.x < cx - 5 ? 'end' : pos.x > cx + 5 ? 'start' : 'middle';
    const name = PRINCIPLE_NAMES[k] ?? k;
    const short = name.length > 16 ? name.slice(0, 14) + '…' : name;
    const color = k.startsWith('ap') ? '#9b4f19' : '#4a6741';
    return `<text x="${pos.x.toFixed(1)}" y="${pos.y.toFixed(1)}" text-anchor="${anchor}" font-size="7.5" fill="${color}" font-family="system-ui,sans-serif" dominant-baseline="middle">${short}</text>`;
  }).join('');
  const dots = VECTOR_KEY.map((k, i) => {
    const s = vec[i] ?? 0;
    if (s === 0) return '';
    const p = spoke(i, r * (s / 3));
    return `<circle cx="${p.x.toFixed(1)}" cy="${p.y.toFixed(1)}" r="3.5" fill="${k.startsWith('ap') ? '#9b4f19' : '#4a6741'}"/>`;
  }).join('');
  return `<svg viewBox="0 0 400 400" xmlns="http://www.w3.org/2000/svg" style="width:100%;height:auto;max-width:420px;">
    <path d="${ring(1/3)}" fill="none" stroke="#ede9e2" stroke-width="1"/>
    <path d="${ring(2/3)}" fill="none" stroke="#d4cdc4" stroke-width="1"/>
    <path d="${ring(1)}"   fill="none" stroke="#a09487" stroke-width="1"/>
    ${spokes}
    <path d="${poly}" fill="rgba(155,79,25,0.10)" stroke="#9b4f19" stroke-width="1.5" stroke-linejoin="round"/>
    ${dots}${labels}
    <text x="${cx}" y="${(cy - r - 8).toFixed(1)}" text-anchor="middle" font-size="7" fill="#a09487" font-family="system-ui,sans-serif">3</text>
    <text x="${cx}" y="${(cy - r * 2/3 - 5).toFixed(1)}" text-anchor="middle" font-size="7" fill="#a09487" font-family="system-ui,sans-serif">2</text>
    <text x="${cx}" y="${(cy - r / 3 - 4).toFixed(1)}" text-anchor="middle" font-size="7" fill="#a09487" font-family="system-ui,sans-serif">1</text>
  </svg>`;
}

const radarSvg = fpVec.length > 0 ? buildRadar(fpVec) : '';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{notFound ? 'Not found' : `Object ${object?.catalog_number ?? id} — Corpus`} · The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
</head>
<body>
  <SiteNav />

  <div class="page">
    <div class="container">
      <div class="top-bar">
        <a href="/corpus" class="back-link">← Corpus</a>
        {!notFound && admin && (
          <button id="deleteBtn" class="delete-btn" data-id={object.id}>Delete object</button>
        )}
      </div>

      {notFound ? (
        <p class="not-found">Object not found.</p>
      ) : (
        <>
          <!-- Object header -->
          <div class="object-header">
            <div class="object-images">
              {imgKeys.map((key: string, i: number) => (
                <figure>
                  <img src={`/api/image/${key}`} alt={`View ${i + 1}`} />
                  <figcaption>{key.split('/').pop()?.replace(/-analysis\.jpg$/, '').replace(/^\d+-/, '') ?? `View ${i + 1}`}</figcaption>
                </figure>
              ))}
              {imgKeys.length === 0 && (
                <div class="no-image">No image stored</div>
              )}
            </div>

            <div class="object-info">
              <p class="object-eyebrow">Object #{object.id}{object.fingerprinted_at ? ' · Fingerprinted' : ' · No fingerprint'}</p>
              <h1>{object.catalog_number ?? `Object ${object.id}`}</h1>

              <dl class="catalog">
                {object.attribution_culture && <div><dt>Culture</dt><dd>{object.attribution_culture} {object.attribution_confidence && <span class="conf">({object.attribution_confidence})</span>}</dd></div>}
                {object.catalog_number     && <div><dt>Catalog no.</dt><dd>{object.catalog_number}</dd></div>}
                {object.accession_number   && <div><dt>Accession lot</dt><dd>{object.accession_number}</dd></div>}
                {object.source_institution && <div><dt>Institution</dt><dd>{object.source_institution}</dd></div>}
                {canonical?.period         && <div><dt>Period</dt><dd>{canonical.period}</dd></div>}
                {canonical?.material       && <div><dt>Material</dt><dd>{canonical.material}</dd></div>}
                {canonical?.site           && <div><dt>Site</dt><dd>{canonical.site}</dd></div>}
                {object.ezid_ark           && <div><dt>EZID / ARK</dt><dd><a href={`http://${object.ezid_ark}`} target="_blank" rel="noopener">{object.ezid_ark.slice(0, 40)}…</a></dd></div>}
                <div><dt>Cataloged</dt><dd>{new Date(object.created_at).toLocaleDateString('en-US', { month: 'long', day: 'numeric', year: 'numeric' })}</dd></div>
              </dl>
            </div>
          </div>

          <!-- Cross-source claims -->
          {claims.length > 1 && (
            <section class="claims-section">
              <h2>
                Cross-source claims
                {object.claim_conflict ? <span class="conflict-badge">⚠ sources disagree</span> : null}
              </h2>
              <p class="section-sub">
                {claims.length} source{claims.length !== 1 ? 's' : ''} have asserted claims about this object.
                {object.claim_conflict
                  ? 'The cultural attributions differ — this is a research flag, not a conclusion. Flagged for closer examination.'
                  : 'All sources agree on the cultural attribution.'}
              </p>
              <div class="claims-list">
                {claims.map((c: any) => {
                  const disagrees = object.claim_conflict && c.attribution_culture &&
                    c.attribution_culture.toLowerCase().trim() !== (object.attribution_culture ?? '').toLowerCase().trim();
                  return (
                    <div class={`claim-row ${disagrees ? 'claim-conflict' : ''}`}>
                      <p class="claim-institution">{c.source_institution}</p>
                      <p class="claim-culture">
                        {c.attribution_culture ?? '—'}
                        {disagrees && <span class="claim-conflict-label"> ← differs from primary</span>}
                      </p>
                      <p class="claim-date">{new Date(c.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</p>
                    </div>
                  );
                })}
              </div>
            </section>
          )}

          <!-- Fingerprint -->
          {fpVec.length > 0 && (
            <section class="fp-section">
              <h2>Perceptual fingerprint</h2>
              <p class="section-sub">Scored blind from Pass 1 — no documentation in context. Model: {object.fingerprint_model ?? '—'}</p>

              <div class="fp-layout">
                <!-- Radar -->
                <div class="fp-radar-wrap" set:html={radarSvg} />

                <!-- Bars -->
                <div class="fp-body">
                  <div class="fp-bars">
                    {VECTOR_KEY.map((k, i) => {
                      const s = fpVec[i] ?? 0;
                      return (
                        <div class="fp-row">
                          <span class="fp-code">{k}</span>
                          <div class="fp-track"><div class="fp-fill" style={`width:${(s/3)*100}%;background:${scoreColor(s)}`}></div></div>
                          <span class="fp-score">{s}</span>
                          <a class="fp-name" href={`/principles#${k}`}>{PRINCIPLE_NAMES[k] ?? k}</a>
                        </div>
                      );
                    })}
                  </div>
                </div>
              </div>

              {object.fingerprint_pass1_text && (
                <div class="fp-pass1">
                  <p class="fp-pass1-label">Pass 1 — blind observation</p>
                  <div class="fp-pass1-text prose" set:html={renderMarkdown(object.fingerprint_pass1_text)} />
                </div>
              )}
            </section>
          )}

          <!-- Past analyses -->
          {analyses.length > 0 && (
            <section class="analyses-section">
              <h2>Past analyses <span class="count">({analyses.length})</span></h2>
              <div class="analyses-list">
                {analyses.map((a: any) => (
                  <div class="analysis-row">
                    <div class="analysis-meta">
                      <span class="analysis-mode">{a.mode}</span>
                      <span class="analysis-audience">{a.audience}</span>
                      {a.tradition && <span class="analysis-tradition">{a.tradition}</span>}
                      {a.tradition_confidence && <span class="conf">({a.tradition_confidence})</span>}
                      <span class="analysis-date">{new Date(a.created_at).toLocaleDateString('en-US', { month: 'short', day: 'numeric', year: 'numeric' })}</span>
                      <div class="analysis-actions">
                        <a href={`/corpus/${object.id}/analysis/${a.id}`} class="analysis-action-link">View full →</a>
                        <a href={`/api/analysis/${a.id}?format=md`} download class="analysis-action-link">↓ .md</a>
                      </div>
                    </div>
                    {a.pass2_text && (
                      <div class="analysis-excerpt prose" set:html={renderMarkdown(a.pass2_text)} />
                    )}
                    {a.fingerprint_flag && (() => {
                      let flag: any = null;
                      try { flag = JSON.parse(a.fingerprint_flag); } catch {}
                      return flag ? (
                        <div class={`fp-flag flag-${flag.alignment}`}>
                          <p class="fp-disclaimer">Provisional heuristic — not a validated comparison; no reference-corpus baseline exists yet.</p>
                          <span class="flag-badge" data-tooltip={ALIGNMENT_TOOLTIPS[flag.alignment]}>{flag.alignment}</span>
                          <span class="flag-strength" data-tooltip={STRENGTH_TOOLTIPS[flag.flag_strength]}>{flag.flag_strength}</span>
                          <p class="flag-reason">{flag.reasoning}</p>
                          {flag.caveats && <p class="flag-caveat">{flag.caveats}</p>}
                        </div>
                      ) : null;
                    })()}
                  </div>
                ))}
              </div>
            </section>
          )}

          {admin && (
          <section class="run-section">
            <h2>Run analysis</h2>
            <p class="section-sub">Passes 2, 3, and 4. Documentation is available as context. Results are stored against this object.</p>

            <div class="run-form">
              <div class="run-controls">
                <div class="control-group">
                  <label class="control-label">Mode</label>
                  <div class="btn-group" id="modeGroup">
                    <button type="button" class="mode-btn active" data-value="artifact">Artifact</button>
                    <button type="button" class="mode-btn" data-value="connections">Connections</button>
                  </div>
                </div>
                <div class="control-group">
                  <label class="control-label">Audience</label>
                  <div class="btn-group" id="audienceGroup">
                    <button type="button" class="aud-btn active" data-value="researcher">Researcher</button>
                    <button type="button" class="aud-btn" data-value="curator">Curator</button>
                    <button type="button" class="aud-btn" data-value="educator">Educator</button>
                  </div>
                </div>
              </div>
              <button type="button" id="runBtn" class="run-btn">Run analysis</button>
            </div>

            <div id="runProgress" style="display:none">
              <div id="runStatus" class="status-log"></div>
              <div id="runPass2Block" style="display:none">
                <p class="block-label">Pass 2 — analysis</p>
                <div id="runPass2Text" class="pass2-text prose"></div>
              </div>
              <div id="runPass3Block" style="display:none">
                <p class="block-label">Pass 3 — what to take forward</p>
                <div id="runPass3Text" class="pass3-text prose"></div>
              </div>
              <div id="runFpFlag" style="display:none">
                <p class="block-label">Heuristic consistency note — provisional</p>
                <p class="fp-disclaimer">Provisional heuristic only — no validated reference corpus exists yet, so this is not a measured comparison against a real distribution.</p>
                <div id="runFpFlagContent" class="fp-flag-block"></div>
              </div>
            </div>
          </section>
          )}
        </>
      )}
    </div>
  </div>

  <SiteFooter />

<script>
  import { renderMarkdown } from '../../lib/markdown';
  window.__marked = (md) => renderMarkdown(md);
</script>

<script define:vars={{ objectId: object?.id }}>
// ── Delete object ──────────────────────────────────────────────────────────

document.getElementById('deleteBtn')?.addEventListener('click', async (e) => {
  const btn = e.currentTarget;
  const id = btn.dataset.id;
  if (!confirm(`Delete object #${id} and all its analyses? This cannot be undone.`)) return;
  btn.textContent = 'Deleting…';
  btn.disabled = true;
  try {
    const res = await fetch(`/api/objects/${id}`, { method: 'DELETE' });
    if (res.ok) {
      window.location.href = '/corpus';
    } else {
      const err = await res.json();
      alert(`Delete failed: ${err.error ?? res.status}`);
      btn.textContent = 'Delete object';
      btn.disabled = false;
    }
  } catch (err) {
    alert(`Error: ${err.message}`);
    btn.textContent = 'Delete object';
    btn.disabled = false;
  }
});

// ── Mode / audience toggles ────────────────────────────────────────────────

let selectedMode = 'artifact';
let selectedAudience = 'researcher';

document.getElementById('modeGroup')?.addEventListener('click', e => {
  const btn = e.target.closest('.mode-btn');
  if (!btn) return;
  document.querySelectorAll('.mode-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  selectedMode = btn.dataset.value;
});

document.getElementById('audienceGroup')?.addEventListener('click', e => {
  const btn = e.target.closest('.aud-btn');
  if (!btn) return;
  document.querySelectorAll('.aud-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  selectedAudience = btn.dataset.value;
});

// ── Run analysis ───────────────────────────────────────────────────────────

document.getElementById('runBtn')?.addEventListener('click', async () => {
  const runBtn      = document.getElementById('runBtn');
  const progress    = document.getElementById('runProgress');
  const statusLog   = document.getElementById('runStatus');
  const pass2Block  = document.getElementById('runPass2Block');
  const pass2Text   = document.getElementById('runPass2Text');
  const pass3Block  = document.getElementById('runPass3Block');
  const pass3Text   = document.getElementById('runPass3Text');
  const fpFlagDiv   = document.getElementById('runFpFlag');
  const fpFlagContent = document.getElementById('runFpFlagContent');

  runBtn.disabled = true;
  runBtn.textContent = 'Running…';
  progress.style.display = '';
  statusLog.innerHTML = '';
  pass2Block.style.display = 'none';
  pass2Text.textContent = '';
  pass3Block.style.display = 'none';
  pass3Text.textContent = '';
  fpFlagDiv.style.display = 'none';

  const addStatus = (msg, isError = false) => {
    const p = document.createElement('p');
    p.className = 'status-line' + (isError ? ' status-error' : '');
    p.textContent = msg;
    statusLog.appendChild(p);
    statusLog.scrollTop = statusLog.scrollHeight;
  };

  try {
    const res = await fetch('/api/analyze', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ object_id: objectId, mode: selectedMode, audience: selectedAudience }),
    });

    if (!res.ok || !res.body) {
      addStatus(`Error ${res.status}`, true);
      runBtn.disabled = false;
      runBtn.textContent = 'Run analysis';
      return;
    }

    const reader = res.body.getReader();
    const decoder = new TextDecoder();
    let buffer = '';
    let pass2Acc = '', pass3Acc = '';

    while (true) {
      const { done, value } = await reader.read();
      if (done) break;
      buffer += decoder.decode(value, { stream: true });
      const lines = buffer.split('\n');
      buffer = lines.pop() ?? '';

      for (const line of lines) {
        if (!line.startsWith('data: ')) continue;
        let evt;
        try { evt = JSON.parse(line.slice(6)); } catch { continue; }

        if (evt.type === 'status') {
          addStatus(evt.message, evt.message.startsWith('⚠'));
        } else if (evt.type === 'delta') {
          pass2Block.style.display = '';
          pass2Acc += evt.text;
          pass2Text.innerHTML = window.__marked(pass2Acc);
        } else if (evt.type === 'error') {
          addStatus(evt.error, true);
        } else if (evt.type === 'complete') {
          if (evt.pass3_text) {
            pass3Block.style.display = '';
            pass3Text.innerHTML = window.__marked(evt.pass3_text);
          }
          if (evt.fingerprint_flag) {
            const flag = evt.fingerprint_flag;
            fpFlagDiv.style.display = '';
            // Build with DOM nodes + textContent — these fields are model output
            // and must never be injected as HTML.
            fpFlagContent.replaceChildren();

            const head = document.createElement('div');
            head.className = 'flag-' + String(flag.alignment ?? '');
            head.style.cssText = 'display:flex;gap:0.5rem;align-items:center;margin-bottom:0.5rem;';
            const ALIGNMENT_TIPS = { aligned: 'Fingerprint scores are perceptually consistent with the claimed tradition', inconclusive: 'Insufficient signal to draw a conclusion — the default for most objects', divergent: 'At least two scores warrant closer human examination' };
            const STRENGTH_TIPS  = { none: 'Nothing flagged for follow-up', weak: 'Minor signals worth noting', moderate: 'More notable signals', strong: 'Significant flags — close examination recommended' };
            const badge = document.createElement('span');
            badge.className = 'flag-badge';
            badge.textContent = flag.alignment ?? '';
            badge.setAttribute('data-tooltip', ALIGNMENT_TIPS[flag.alignment] ?? '');
            const strength = document.createElement('span');
            strength.style.cssText = 'font-size:0.75rem;color:var(--text-muted);font-family:var(--font-mono)';
            strength.textContent = flag.flag_strength ?? '';
            strength.setAttribute('data-tooltip', STRENGTH_TIPS[flag.flag_strength] ?? '');
            head.append(badge, strength);

            const reason = document.createElement('p');
            reason.style.cssText = 'font-size:0.875rem;line-height:1.7;color:var(--text)';
            reason.textContent = flag.reasoning ?? '';

            const caveat = document.createElement('p');
            caveat.style.cssText = 'font-size:0.75rem;color:var(--text-muted);margin-top:0.5rem;font-style:italic';
            caveat.textContent = flag.caveats ?? '';

            fpFlagContent.append(head, reason, caveat);
          }
          if (evt.analysis_id) {
            addStatus(`Saved — analysis #${evt.analysis_id}`);
          }
        }
      }
    }
  } catch (err) {
    addStatus(`Error: ${err.message}`, true);
  } finally {
    runBtn.disabled = false;
    runBtn.textContent = 'Run analysis';
  }
});
</script>

<style>
  .page { padding-block: var(--space-16) var(--space-24); background: var(--bg); }
  .container { max-width: 960px; }
  .top-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: var(--space-8);
  }
  .back-link {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    text-decoration: none;
    letter-spacing: var(--tracking-wide);
  }
  .back-link:hover { color: var(--accent); }
  .delete-btn {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    background: none;
    border: 1px solid var(--border);
    border-radius: var(--radius-xs);
    padding: var(--space-1) var(--space-3);
