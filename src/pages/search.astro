---
export const prerender = true;
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Search — The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
</head>
<body>
  <SiteNav />

  <div class="search-page">
    <div class="container">
      <div class="search-head">
        <h1 class="search-title">Search</h1>
        <p class="search-sub">Search by culture, institution, catalog number, or observation text.</p>
      </div>

      <div class="search-input-wrap">
        <input
          id="searchInput"
          type="search"
          class="search-input"
          placeholder="Mimbres, geometric, Smithsonian, E021234…"
          autocomplete="off"
          spellcheck="false"
        />
      </div>

      <p id="searchStatus" class="search-status">Type to search.</p>
      <div id="grid" class="object-grid" style="display:none"></div>
    </div>
  </div>

  <SiteFooter />

<script>
const esc = s => String(s ?? '').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');

// Replace [[M]]...[[/M]] markers with <mark> after escaping surrounding text.
function highlight(raw) {
  if (!raw) return '';
  return esc(raw)
    .replace(/\[\[M\]\]/g, '<mark>')
    .replace(/\[\[\/M\]\]/g, '</mark>');
}

const input  = document.getElementById('searchInput');
const status = document.getElementById('searchStatus');
const grid   = document.getElementById('grid');

let debounce = null;
let lastQ    = '';

input.addEventListener('input', () => {
  clearTimeout(debounce);
  const q = input.value.trim();
  if (!q) {
    grid.style.display = 'none';
    grid.innerHTML = '';
    status.textContent = 'Type to search.';
    history.replaceState(null, '', '/search');
    return;
  }
  status.textContent = 'Searching…';
  debounce = setTimeout(() => runSearch(q), 300);
});

async function runSearch(q) {
  if (q === lastQ) return;
  lastQ = q;
  history.replaceState(null, '', `/search?q=${encodeURIComponent(q)}`);

  try {
    const res  = await fetch(`/api/search?q=${encodeURIComponent(q)}`);
    const data = await res.json();

    if (!res.ok) {
      status.textContent = data.error ?? 'Search error.';
      grid.style.display = 'none';
      return;
    }

    if (!data.length) {
      status.textContent = `No results for "${q}".`;
      grid.style.display = 'none';
      grid.innerHTML = '';
      return;
    }

    status.textContent = `${data.length} result${data.length !== 1 ? 's' : ''} for "${q}"`;
    grid.style.display = '';
    grid.innerHTML = data.map(obj => {
      const imgKey    = obj.image_analysis_key?.split(',')[0]?.trim();
      const imgSrc    = imgKey ? `/api/image/${imgKey}` : null;
      const displayId = esc(obj.catalog_number ?? `#${obj.id}`);
      const culture   = esc(obj.attribution_culture ?? '—');
      const inst      = esc(obj.source_institution ?? '');
      const excerpt   = obj.excerpt ? highlight(obj.excerpt) : '';
      const fpBadge   = obj.fingerprinted_at
        ? `<span class="card-fp-yes">● Fingerprinted</span>`
        : `<span class="card-fp-no">○ No fingerprint</span>`;

      return `
        <a href="/corpus/${obj.id}" class="object-card">
          ${imgSrc
            ? `<div class="card-image"><img src="${imgSrc}" alt="${displayId}" loading="lazy" /></div>`
            : `<div class="card-no-image">No image</div>`}
          <div class="card-body">
            <p class="card-display-id">${displayId}</p>
            <p class="card-culture">${culture}</p>
            ${inst ? `<p class="card-inst">${inst}</p>` : ''}
            ${excerpt ? `<p class="card-excerpt">${excerpt}</p>` : ''}
            <div class="card-meta">${fpBadge}</div>
          </div>
        </a>`;
    }).join('');
  } catch (err) {
    status.textContent = `Error: ${err.message}`;
    grid.style.display = 'none';
  }
}

// Run search on load if ?q= is present
const initQ = new URLSearchParams(location.search).get('q')?.trim();
if (initQ) {
  input.value = initQ;
  status.textContent = 'Searching…';
  runSearch(initQ);
}
</script>

<style is:global>
  .search-page { padding-block: var(--space-16) var(--space-24); background: var(--bg); min-height: 80vh; }

  .search-head { margin-bottom: var(--space-8); }
  .search-title { font-family: var(--font-display); font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl)); letter-spacing: var(--tracking-snug); font-weight: normal; }
  .search-sub { font-size: var(--text-base); color: var(--text-muted); margin-top: var(--space-2); }

  .search-input-wrap { margin-bottom: var(--space-6); }
  .search-input {
    width: 100%;
    font-family: var(--font-mono);
    font-size: var(--text-base);
    color: var(--text);
    background: var(--bg-surface);
    border: 1px solid var(--border-strong);
    border-radius: var(--radius-sm);
    padding: var(--space-4) var(--space-5);
    outline: none;
    transition: border-color var(--ease), box-shadow var(--ease);
    box-sizing: border-box;
  }
  .search-input::placeholder { color: var(--text-muted); }
  .search-input:focus {
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-dim);
  }
  /* Remove the browser's native search cancel button */
  .search-input::-webkit-search-cancel-button { display: none; }

  .search-status {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text-muted);
    margin-bottom: var(--space-8);
    letter-spacing: var(--tracking-normal);
  }

  /* Cards — same as corpus.astro */
  .object-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-6);
  }
  @media (max-width: 1024px) { .object-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 640px)  { .object-grid { grid-template-columns: repeat(2, 1fr); } }

  .object-card {
    display: block;
    text-decoration: none;
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: border-color var(--ease), box-shadow var(--ease);
    min-width: 0;
  }
  .object-card:hover { border-color: var(--accent); box-shadow: var(--shadow-accent); }

  .card-image { width: 100%; aspect-ratio: 1; overflow: hidden; background: var(--bg-alt); display: block; }
  .card-image img { width: 100%; height: 100%; object-fit: cover; object-position: center top; display: block; }
  .card-no-image {
    width: 100%; aspect-ratio: 1; display: flex; align-items: center; justify-content: center;
    font-size: 0.7rem; color: var(--text-muted); font-family: var(--font-mono); background: var(--bg-alt);
  }

  .card-body { padding: var(--space-3) var(--space-4); display: flex; flex-direction: column; gap: var(--space-2); }
  .card-display-id { font-family: var(--font-mono); font-size: var(--text-sm); color: var(--text); font-weight: var(--weight-semibold); max-width: none; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .card-culture { font-size: var(--text-sm); color: var(--text-muted); max-width: none; }
  .card-inst { font-size: var(--text-xs); color: var(--text-subtle); font-family: var(--font-mono); max-width: none; }
  .card-excerpt {
    font-size: var(--text-xs); color: var(--text-muted); line-height: var(--leading-relaxed);
    display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
    max-width: none;
  }
  .card-excerpt mark { background: var(--accent-dim); color: var(--text); border-radius: var(--radius-xs); padding: 0 1px; }
  .card-meta { display: flex; align-items: center; }
  .card-fp-yes { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: var(--tracking-wide); color: var(--cons); }
  .card-fp-no  { font-family: var(--font-mono); font-size: 0.65rem; letter-spacing: var(--tracking-wide); color: var(--text-muted); }
</style>
</body>
</html>
