---
export const prerender = true;
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';
import artifactPrinciplesData from '../data/artifact-principles.json';
import hgPrinciplesData from '../data/hg-principles.json';

const APPLICABLE_TA_IDS = new Set([1, 2, 4, 5, 13, 15, 20, 28, 47, 48, 49, 51]);

const artifactPrinciples = (artifactPrinciplesData as any).principles as any[];
const visualPrinciples = ((hgPrinciplesData as any).principles as any[])
  .filter((p: any) => APPLICABLE_TA_IDS.has(p.id));

// Code key in vector order, matching VECTOR_KEY in analysis pages
const AP_CODES: Record<number, string> = Object.fromEntries(
  artifactPrinciples.map((p: any, i: number) => [p.id, `ap_${i + 1}`])
);
const TA_CODES: Record<number, string> = {
  1: 'ta_1', 2: 'ta_2', 4: 'ta_4', 5: 'ta_5',
  13: 'ta_13', 15: 'ta_15', 20: 'ta_20', 28: 'ta_28',
  47: 'ta_47', 48: 'ta_48', 49: 'ta_49', 51: 'ta_51',
};

const SCORE_LEVELS = [
  { score: 0, label: 'Not detected', description: 'The principle is not present or not applicable to this object.' },
  { score: 1, label: 'Weakly present', description: 'The principle is present but faint — low evidence, requires inference.' },
  { score: 2, label: 'Clearly present', description: 'The principle is evident and directly readable from the image.' },
  { score: 3, label: 'Strongly present', description: 'The principle is a dominant feature — high evidence, clearly intentional.' },
];

function scoreColor(s: number) {
  return s === 0 ? 'var(--border-strong)' : s === 1 ? '#c8a882' : s === 2 ? 'var(--accent-light)' : 'var(--accent)';
}
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="description" content="The 27 perceptual principles used to compute a visual fingerprint for archaeological objects — what they are, how they're scored, and what each one looks for." />
  <title>The 27 Principles — The Grammar of Things</title>
  <style is:global>
    @import url('/src/styles/base.css');
  </style>
</head>
<body>
  <SiteNav />

  <div class="page">
    <div class="container">

      <!-- ── Page header ── -->
      <header class="page-header">
        <p class="eyebrow">Reference</p>
        <h1>The 27 Principles</h1>
        <p class="intro">
          Every object analyzed by this system is scored against 27 perceptual principles — what the image actually shows, independent of what the documentation claims. The result is a fingerprint: a vector that represents how the object performs across each principle. That fingerprint is computed before any cultural attribution is consulted, then compared against it.
        </p>
        <p class="intro">
          The 27 principles come from two distinct domains. The first 15 are artifact-specific — perceptual habits developed for reading archaeological and anthropological objects: production traces, wear patterns, material boundaries, construction evidence. The remaining 12 are universal visual principles drawn from perceptual science: how the human visual system processes edges, groupings, figure-ground relationships, and surface properties. Both domains apply simultaneously to every object.
        </p>
      </header>

      <!-- ── Score scale ── -->
      <section class="score-section">
        <h2>How scoring works</h2>
        <p class="section-sub">Each principle receives a score from 0 to 3, assigned during Pass 1 — the blind read. The score reflects how strongly that principle is present in the image, not how important it is.</p>
        <div class="score-grid">
          {SCORE_LEVELS.map(level => (
            <div class="score-row">
              <div class="score-badge" style={`background:${scoreColor(level.score)};color:${level.score === 0 ? 'var(--text-muted)' : '#fff'}`}>
                {level.score}
              </div>
              <div>
                <p class="score-label">{level.label}</p>
                <p class="score-desc">{level.description}</p>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- ── Artifact-domain principles ── -->
      <section class="principles-section">
        <div class="section-header">
          <h2>Artifact-domain principles</h2>
          <span class="section-count">15 principles · ap_1 – ap_15</span>
        </div>
        <p class="section-sub">
          Perceptual habits developed specifically for reading archaeological objects. These direct attention toward production evidence, use history, and material relationships — the observational moves that make an artifact legible as a made thing with a history.
        </p>

        <div class="principles-list">
          {artifactPrinciples.map((p: any, i: number) => {
            const code = `ap_${i + 1}`;
            return (
              <article class="principle-card" id={code}>
                <div class="principle-code-col">
                  <span class="principle-code ap-code">{code}</span>
                </div>
                <div class="principle-body">
                  <h3 class="principle-name">{p.name}</h3>
                  {p.subtitle && <p class="principle-subtitle">{p.subtitle}</p>}
                  <p class="principle-description">{p.description}</p>
                  {p.howToApply && (
                    <div class="principle-apply">
                      <span class="apply-label">How to read it</span>
                      <p>{p.howToApply}</p>
                    </div>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </section>

      <!-- ── Universal visual principles ── -->
      <section class="principles-section">
        <div class="section-header">
          <h2>Universal visual principles</h2>
          <span class="section-count">12 principles · ta_* subset</span>
        </div>
        <p class="section-sub">
          Perceptual mechanisms shared across all visual analysis — how the human visual system processes edges, groupings, figure-ground relationships, color, and surface properties. These apply to artifact observation regardless of object type or cultural domain. Six additional Tier A principles (linear perspective, atmospheric perspective, light source logic, common fate, elevation in picture plane, binocular depth cues) were excluded as fine-art-specific and not applicable to artifact reading.
        </p>

        <div class="principles-list">
          {visualPrinciples.map((p: any) => {
            const code = TA_CODES[p.id];
            return (
              <article class="principle-card" id={code}>
                <div class="principle-code-col">
                  <span class="principle-code ta-code">{code}</span>
                </div>
                <div class="principle-body">
                  <h3 class="principle-name">{p.name}</h3>
                  {p.subtitle && <p class="principle-subtitle">{p.subtitle}</p>}
                  {p.neuralFact && (
                    <p class="principle-description">{p.neuralFact}</p>
                  )}
                  {p.studioTool && (
                    <div class="principle-apply">
                      <span class="apply-label">In artifact observation</span>
                      <p>{p.studioTool}</p>
                    </div>
                  )}
                </div>
              </article>
            );
          })}
        </div>
      </section>

    </div>
  </div>

  <SiteFooter />
</body>
</html>

<style>
  .page { padding-block: var(--space-16) var(--space-24); background: var(--bg); }
  .container { max-width: 860px; }

  /* ── Page header ── */
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-3);
    max-width: none;
  }
  h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    letter-spacing: -0.02em;
    margin-bottom: var(--space-6);
  }
  .page-header { margin-bottom: var(--space-16); padding-bottom: var(--space-12); border-bottom: 2px solid var(--border-strong); }
  .intro { font-size: var(--text-lg); line-height: 1.8; color: var(--text); margin-bottom: var(--space-4); max-width: 68ch; }

  /* ── Score scale ── */
  .score-section { margin-bottom: var(--space-16); padding-bottom: var(--space-12); border-bottom: 1px solid var(--border); }
  h2 { font-size: var(--text-2xl); letter-spacing: -0.01em; margin-bottom: var(--space-2); }
  .section-sub { font-size: var(--text-sm); color: var(--text-muted); margin-bottom: var(--space-8); max-width: 62ch; line-height: 1.7; }
  .score-grid { display: flex; flex-direction: column; gap: var(--space-3); max-width: 580px; }
  .score-row { display: grid; grid-template-columns: 42px 1fr; gap: var(--space-6); align-items: start; padding: var(--space-3) 0; border-bottom: 1px solid var(--bg-alt); }
  .score-row:last-child { border-bottom: none; }
  .score-badge {
    width: 36px; height: 36px; border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-mono); font-size: var(--text-base); font-weight: var(--weight-bold);
    flex-shrink: 0;
  }
  .score-label { font-weight: var(--weight-semibold); font-size: var(--text-sm); color: var(--text); margin-bottom: 0.15em; max-width: none; }
  .score-desc  { font-size: var(--text-sm); color: var(--text-muted); line-height: 1.6; max-width: none; }

  /* ── Principles sections ── */
  .principles-section { margin-bottom: var(--space-20); }
  .section-header { display: flex; align-items: baseline; gap: var(--space-6); flex-wrap: wrap; margin-bottom: var(--space-2); }
  .section-count { font-family: var(--font-mono); font-size: var(--text-xs); color: var(--text-muted); letter-spacing: 0.04em; }
  .principles-list { display: flex; flex-direction: column; gap: 0; }

  /* ── Principle card ── */
  .principle-card {
    display: grid;
    grid-template-columns: 64px 1fr;
    gap: var(--space-6);
    padding: var(--space-8) 0;
    border-bottom: 1px solid var(--border);
    scroll-margin-top: var(--space-8);
  }
  .principle-card:last-child { border-bottom: none; }
  .principle-card:target { background: var(--accent-dim); margin-inline: calc(-1 * var(--space-6)); padding-inline: var(--space-6); border-radius: var(--radius-sm); }

  .principle-code-col { padding-top: 4px; }
  .principle-code {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: 0.04em;
    padding: 0.2em 0.5em;
    border-radius: var(--radius-sm);
  }
  .ap-code { color: var(--accent);  background: var(--accent-dim); }
  .ta-code { color: var(--cons);    background: var(--cons-bg);   }

  .principle-name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: normal;
    color: var(--text);
    margin-bottom: var(--space-1);
    line-height: 1.3;
  }
  .principle-subtitle {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.03em;
    margin-bottom: var(--space-4);
    max-width: none;
    font-style: italic;
  }
  .principle-description {
    font-size: var(--text-base);
    line-height: 1.8;
    color: var(--text);
    margin-bottom: var(--space-4);
    max-width: 64ch;
  }
  .principle-apply {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    padding: var(--space-4) var(--space-6);
  }
  .apply-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-semibold);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    color: var(--accent);
    display: block;
    margin-bottom: var(--space-2);
  }
  .principle-apply p {
    font-size: var(--text-sm);
    line-height: 1.75;
    color: var(--text-muted);
    max-width: 60ch;
  }

  @media (max-width: 600px) {
    .principle-card { grid-template-columns: 1fr; gap: var(--space-3); }
    .section-header { flex-direction: column; gap: var(--space-1); }
  }
</style>
