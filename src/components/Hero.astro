---
import type { HeroContent } from '../data/hero-imls';
interface Props { content: HeroContent }
const { content } = Astro.props;
---
<section id="hero">
  <div class="container">
    <div class="hero-body">
      <p class="eyebrow">{content.eyebrow}</p>
      <h1>{content.headline}</h1>
      <p class="subhead">{content.subhead}</p>
      <a href={content.ctaHref} class="cta">{content.ctaText} →</a>
      <p class="note">{content.note}</p>
    </div>
    <div class="hero-image">
      <div class="image-wrap">
        <img
          src="/images/bowl-interior.jpg"
          alt={content.imageAlt}
          class="bowl-photo"
        />
        <div class="analysis-overlay">
          <p class="overlay-pass">Pass 1 — blind observation</p>
          <p class="overlay-line">
            Oblique striations on exterior: coil-and-scrape construction.
            <span class="chip obs">[OBS]</span>
          </p>
          <p class="overlay-line">
            Two-zone interior: framing band + central geometric field.
            <span class="chip obs">[OBS]</span>
          </p>
          <p class="overlay-line">
            Positive-negative capacity: deliberate compositional property.
            <span class="chip interp">[INTERP]</span>
          </p>
        </div>
      </div>
      <p class="image-caption">{content.imageCaption}</p>
    </div>
  </div>
</section>

<style>
  section {
    padding-block: var(--space-24);
    border-bottom: 1px solid var(--border);
  }
  .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }
  .hero-body { display: flex; flex-direction: column; gap: var(--space-6); }
  .eyebrow {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    color: var(--accent);
    text-transform: uppercase;
    max-width: none;
  }
  h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    letter-spacing: -0.02em;
    max-width: 16ch;
  }
  .subhead {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: 1.7;
  }
  .cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    letter-spacing: 0.02em;
    align-self: flex-start;
  }
  .cta:hover { color: var(--accent-light); border-color: var(--accent-light); }
  .note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    padding: var(--space-4);
    border-left: 3px solid var(--border-strong);
    background: var(--bg-alt);
    max-width: none;
  }
  .hero-image {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }
  .image-wrap {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .bowl-photo {
    display: block;
    width: 100%;
    height: auto;
    aspect-ratio: 4/3;
    object-fit: cover;
    object-position: center top;
  }
  .analysis-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: linear-gradient(transparent, rgba(28, 25, 23, 0.92));
    padding: var(--space-8) var(--space-6) var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .overlay-pass {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: var(--space-1);
    max-width: none;
  }
  .overlay-line {
    font-size: var(--text-sm);
    color: rgba(255,255,255,0.88);
    line-height: 1.5;
    display: flex;
    align-items: baseline;
    gap: var(--space-2);
    flex-wrap: wrap;
    max-width: none;
  }
  .chip {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.03em;
    padding: 0.1em 0.4em;
    border-radius: 2px;
    flex-shrink: 0;
    vertical-align: middle;
  }
  .chip.obs    { background: var(--obs-bg);    color: var(--obs);    }
  .chip.interp { background: var(--interp-bg); color: var(--interp); }
  .image-caption {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    line-height: 1.5;
    max-width: none;
  }
  @media (max-width: 900px) {
    .container { grid-template-columns: 1fr; }
    .hero-image { display: none; }
  }
</style>
