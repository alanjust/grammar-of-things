---
import type { HeroContent } from '../data/hero-imls';
interface Props { content: HeroContent }
const { content } = Astro.props;
---
<section id="hero">
  <div class="container">

    <div class="hero-body">
      <p class="eyebrow">{content.eyebrow}</p>
      <h1>{content.headline}</h1>
      <p class="subhead">{content.subhead}</p>
      <a href={content.ctaHref} class="cta">{content.ctaText} →</a>
      <p class="note">{content.note}</p>
    </div>

    <!-- Right panel: the real object, above the fold -->
    <a href="/corpus/2" class="object-panel" aria-label="View Bowl A326247 in corpus: object detail and analysis">
      <div class="panel-images">
        <div class="img-wrap img-primary">
          <img src="/images/bowl-interior.jpg" alt="Bowl A326247 — interior" />
          <span class="view-label">Interior</span>
        </div>
        <div class="img-wrap">
          <img src="/images/bowl-exterior.jpg" alt="Bowl A326247 — exterior" />
          <span class="view-label">Exterior</span>
        </div>
      </div>
      <div class="panel-meta">
        <p class="meta-title">Bowl A326247</p>
        <p class="meta-line">Mimbres · Luna County, NM · 1923</p>
        <p class="meta-line">NMNH, Smithsonian Institution</p>
        <p class="meta-line meta-cta">Read complete analysis →</p>
      </div>
      <div class="panel-tags">
        <span class="tag tag-obs">[OBS] 7 direct observations</span>
        <span class="tag tag-cons">[CONS] 5 scholarly anchors</span>
        <span class="tag tag-fp">29-principle fingerprint</span>
      </div>
    </a>

  </div>
</section>

<style>
  section {
    padding-block: var(--space-24);
    border-bottom: 1px solid var(--border);
  }
  .container {
    display: grid;
    grid-template-columns: 1fr 420px;
    gap: var(--space-16);
    align-items: center;
  }
  .hero-body { display: flex; flex-direction: column; gap: var(--space-6); }
  .eyebrow {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-widest);
    color: var(--accent);
    text-transform: uppercase;
    max-width: none;
  }
  h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    letter-spacing: var(--tracking-tight);
    max-width: 16ch;
  }
  .subhead {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: var(--leading-body);
  }
  .cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    letter-spacing: 0.02em;
    align-self: flex-start;
  }
  .cta:hover { color: var(--accent-light); border-color: var(--accent-light); }
  .note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    padding: var(--space-4);
    border-left: 3px solid var(--border-strong);
    background: var(--bg-alt);
    max-width: none;
  }

  /* Object panel */
  .object-panel {
    display: flex;
    flex-direction: column;
    gap: var(--space-5);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--space-7);
    text-decoration: none;
    transition: border-color var(--ease), box-shadow var(--ease);
  }
  .object-panel:hover {
    border-color: var(--accent);
    box-shadow: var(--shadow-md);
  }
  .panel-images {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-3);
  }
  .img-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-xs);
    border: 1px solid var(--border);
  }
  .img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    display: block;
  }
  .img-primary { aspect-ratio: 1; }
  .img-wrap:not(.img-primary) { aspect-ratio: 1; }
  .view-label {
    position: absolute;
    bottom: var(--space-2);
    left: var(--space-2);
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: var(--tracking-wider);
    text-transform: uppercase;
    color: rgba(255,255,255,0.8);
    background: rgba(28,25,23,0.6);
    padding: 0.1em 0.4em;
    border-radius: var(--radius-xs);
  }
  .panel-meta { display: flex; flex-direction: column; gap: var(--space-2); padding-inline: var(--space-1); }
  .meta-title {
    font-family: var(--font-display);
    font-size: var(--text-lg);
    color: var(--text);
    max-width: none;
  }
  .meta-line { font-size: var(--text-sm); color: var(--text-muted); max-width: none; }
  .meta-cta {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: var(--tracking-wide);
    margin-top: var(--space-1);
  }
  .panel-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    padding-top: var(--space-2);
    border-top: 1px solid var(--border);
  }
  .tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    letter-spacing: var(--tracking-wide);
    padding: 0.15em 0.5em;
    border-radius: var(--radius-xs);
  }
  .tag-obs    { background: var(--obs-bg);   color: var(--obs);   }
  .tag-cons   { background: var(--cons-bg);  color: var(--cons);  }
  .tag-fp     { background: var(--bg-alt);   color: var(--text-muted); border: 1px solid var(--border); }

  @media (max-width: 1024px) {
    .container { grid-template-columns: 1fr 360px; gap: var(--space-10); }
  }
  @media (max-width: 768px) {
    .container { grid-template-columns: 1fr; }
    .object-panel { display: none; }
  }
</style>
