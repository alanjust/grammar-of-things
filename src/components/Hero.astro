---
import type { HeroContent } from '../data/hero-imls';
interface Props { content: HeroContent }
const { content } = Astro.props;
---
<section id="hero">
  <div class="container">
    <div class="hero-body">
      <p class="eyebrow">{content.eyebrow}</p>
      <h1>{content.headline}</h1>
      <p class="subhead">{content.subhead}</p>
      <a href={content.ctaHref} class="cta">{content.ctaText} →</a>
      <p class="note">{content.note}</p>
    </div>
    <div class="hero-image" role="img" aria-label={content.imageAlt}>
      <div class="image-placeholder">
        <span class="placeholder-label">Analysis preview</span>
        <p class="placeholder-caption">{content.imageCaption}</p>
      </div>
    </div>
  </div>
</section>

<style>
  section {
    padding-block: var(--space-24);
    border-bottom: 1px solid var(--border);
  }
  .container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-16);
    align-items: center;
  }
  .hero-body { display: flex; flex-direction: column; gap: var(--space-6); }
  .eyebrow {
    font-size: var(--text-xs);
    font-family: var(--font-mono);
    letter-spacing: 0.08em;
    color: var(--accent);
    text-transform: uppercase;
    max-width: none;
  }
  h1 {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
    letter-spacing: -0.02em;
    max-width: 16ch;
  }
  .subhead {
    font-size: var(--text-lg);
    color: var(--text-muted);
    line-height: 1.7;
  }
  .cta {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 1px;
    letter-spacing: 0.02em;
    align-self: flex-start;
  }
  .cta:hover { color: var(--accent-light); border-color: var(--accent-light); }
  .note {
    font-size: var(--text-sm);
    color: var(--text-muted);
    padding: var(--space-4);
    border-left: 3px solid var(--border-strong);
    background: var(--bg-alt);
    max-width: none;
  }
  .hero-image {
    border-radius: 4px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .image-placeholder {
    background: var(--bg-alt);
    aspect-ratio: 4/3;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: var(--space-4);
    padding: var(--space-8);
    text-align: center;
  }
  .placeholder-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    padding: var(--space-2) var(--space-4);
    border-radius: 2px;
  }
  .placeholder-caption {
    font-size: var(--text-sm);
    color: var(--text-muted);
    max-width: 36ch;
    line-height: 1.5;
  }
  @media (max-width: 900px) {
    .container { grid-template-columns: 1fr; }
    .hero-image { display: none; }
  }
</style>
