---
// Proof section — fixed, built around the cataloged Mimbres bowl (NMNH 070367 / A326247).
// Shows epistemic labels, RAP flags, and the 27-principle fingerprint.
// Specimen analysis is representative of actual tool output format.

const fingerprint = [
  // Artifact-domain principles (ap_1–ap_15)
  { code: 'ap_1',  name: 'Production Trace Reading',    score: 3, desc: 'Reads surface marks as evidence of how the object was made' },
  { code: 'ap_2',  name: 'Sequence Inference',           score: 2, desc: 'Infers construction stages from layered physical evidence' },
  { code: 'ap_3',  name: 'Material Boundary Attention',  score: 2, desc: 'Registers where one material or treatment ends and another begins' },
  { code: 'ap_4',  name: 'Wear Differential',            score: 1, desc: 'Notes where surfaces show more or less wear than neighbors' },
  { code: 'ap_5',  name: 'Absence as Evidence',          score: 2, desc: 'Treats gaps, holes, and missing elements as data, not gaps' },
  { code: 'ap_6',  name: 'Composite Detection',          score: 0, desc: 'Identifies objects made from more than one material' },
  { code: 'ap_7',  name: 'Anatomical Correspondence',    score: 0, desc: 'Maps figurative forms onto animal or human anatomy' },
  { code: 'ap_8',  name: 'Symmetry as Evidence',         score: 3, desc: 'Reads bilateral or rotational symmetry as a structural commitment' },
  { code: 'ap_9',  name: 'Proportion as Encoding',       score: 2, desc: 'Registers size relationships between parts as meaningful' },
  { code: 'ap_10', name: 'Color Zone Logic',             score: 3, desc: 'Maps how color areas are organized across the object surface' },
  { code: 'ap_11', name: 'Investment Gradient',          score: 2, desc: 'Reads varying labor investment as a signal of priority' },
  { code: 'ap_12', name: 'Attachment Point Reading',     score: 1, desc: 'Identifies holes, grooves, and residue from joining or binding' },
  { code: 'ap_13', name: 'Orientation Dependency',       score: 1, desc: 'Notes which features only read correctly at a specific orientation' },
  { code: 'ap_14', name: 'Completion State',             score: 2, desc: 'Distinguishes finished from interrupted or deliberately partial work' },
  { code: 'ap_15', name: 'Reduction vs. Construction',   score: 1, desc: 'Determines whether form was built up or carved away' },
  // Universal Tier A principles (subset applicable to artifact observation)
  { code: 'ta_1',  name: 'Edge Detection',               score: 3, desc: 'Line quality as production evidence — consistency, control, hesitation' },
  { code: 'ta_2',  name: 'Color Opponent Channels',      score: 3, desc: 'Black/white contrast — the organizing system of the design' },
  { code: 'ta_4',  name: 'Figure-Ground Relationships',  score: 3, desc: 'Positive-negative ambiguity — readable as dark-on-light or light-on-dark' },
  { code: 'ta_5',  name: 'Grouping',                     score: 2, desc: 'How individual marks cluster into compositional units' },
  { code: 'ta_13', name: 'Overlap / Occlusion',          score: 1, desc: 'Which elements sit in front, implying depth' },
  { code: 'ta_15', name: 'Closure / Negative Space',     score: 3, desc: 'Negative space is designed, not residual — the ground is active' },
  { code: 'ta_20', name: 'Simultaneous Contrast',        score: 2, desc: 'Juxtaposed black and white amplify each other' },
  { code: 'ta_28', name: 'Specularity / Surface Reflection', score: 1, desc: 'Surface sheen differential — matte mineral paint vs. slip' },
  { code: 'ta_47', name: 'Face Detection',               score: 0, desc: 'Registers face-like configurations in the design' },
  { code: 'ta_48', name: 'Biological Motion Detection',  score: 0, desc: 'Detects movement-suggestive figurative forms' },
  { code: 'ta_49', name: 'Gaze Direction / Social Attention', score: 0, desc: 'Responds to depicted eyes or gaze vectors' },
  { code: 'ta_51', name: 'Visual Pop-out / Pre-attentive Features', score: 2, desc: 'Elements that register before effortful attention' },
];

const rapFlags = [
  {
    claim_type: 'tradition_attribution',
    confidence: 'reading',
    claim: 'Classic Mimbres Black-on-white (~850–1150 CE): brilliant white slip, single dark mineral pigment, interior-dominant central medallion composition, coil-and-scrape construction.',
    anchor_count: 5,
    gloss: 'Five independent observable indicators converge on the same tradition — this is the strongest evidence category.',
  },
  {
    claim_type: 'functional_claim',
    confidence: 'hypothesis',
    claim: 'Mortuary context: kill hole present at base, consistent with Mimbres burial bowl practice. Burial context confirmed by kill hole; associated assemblage unknown.',
    anchor_count: 2,
    gloss: 'Two anchors support this claim (kill hole presence + tradition convention). Burial confirmation requires provenience documentation.',
  },
  {
    claim_type: 'iconographic_meaning',
    confidence: 'hypothesis',
    claim: 'Positive-negative ambiguity in the geometric field is a deliberate compositional strategy, not incidental — the design reads simultaneously as dark-on-light and light-on-dark.',
    anchor_count: 3,
    gloss: 'Three formal observations anchor this. Named by Brody as a specific Mimbres technical achievement — not a general formal virtue.',
  },
];

function scoreColor(score: number) {
  if (score === 0) return 'score-0';
  if (score === 1) return 'score-1';
  if (score === 2) return 'score-2';
  return 'score-3';
}

const artifactPrinciples = fingerprint.slice(0, 15);
const universalPrinciples = fingerprint.slice(15);
---

<section id="proof">
  <div class="container">

    <div class="section-head">
      <p class="section-label">The proof</p>
      <h2>One real object, read all the way through</h2>
      <p class="section-sub">
        Mimbres Black-on-white bowl — NMNH catalog 070367 / accession A326247.<br>
        National Museum of Natural History, Smithsonian Institution.
      </p>
    </div>

    <!-- Epistemic label legend -->
    <div class="legend">
      <p class="legend-head">How to read this analysis</p>
      <div class="legend-items">
        <div class="legend-item">
          <span class="label label-obs">[OBS]</span>
          <span>Direct observation — what is physically present and visible in the image. No inference required.</span>
        </div>
        <div class="legend-item">
          <span class="label label-interp">[INTERP]</span>
          <span>Interpretation — what the evidence means. Requires at least two independent observable anchors.</span>
        </div>
        <div class="legend-item">
          <span class="label label-cons">[CONS]</span>
          <span>Scholarly consensus — claim supported by the primary literature (Brody, Shafer, Wilson, etc.).</span>
        </div>
        <div class="legend-item">
          <span class="label label-theory">[THEORY]</span>
          <span>Theoretical framework — an analytical lens applied to interpretation, named explicitly.</span>
        </div>
      </div>
    </div>

    <!-- Analysis excerpt -->
    <div class="analysis-block">
      <div class="analysis-meta">
        <p class="analysis-title">Pass 1 — blind observation (documentation excluded)</p>
        <p class="analysis-note">The fingerprint is computed from the image alone. No cultural documentation was available to the model at this stage.</p>
      </div>
      <div class="analysis-text">
        <p>
          <strong>Production Trace Reading:</strong> The exterior surface shows oblique striations consistent with coil-and-scrape construction. <span class="label label-obs">[OBS]</span>
          Interior slip appears evenly applied across the full bowl interior, with no visible underlayer or adhesion failure. <span class="label label-obs">[OBS]</span>
          Line work is single-stroke throughout — no evidence of hesitation or correction at direction changes. <span class="label label-obs">[OBS]</span>
        </p>
        <p>
          <strong>Color Zone Logic + Edge Detection:</strong> The design area is organized as a two-zone composition: a framing band at the rim and a central field. <span class="label label-obs">[OBS]</span>
          Primary design lines maintain consistent width across the full circumference, approximately 2–3mm, with minimal variation at turns. <span class="label label-obs">[OBS]</span>
          The slip ground reads as brilliant white to cream; the painted elements are a matte dark brown-black consistent with mineral pigment. <span class="label label-obs">[OBS]</span>
        </p>
        <p>
          <strong>Absence as Evidence:</strong>
          A circular perforation is present at the base — punched rather than drilled, based on scar profile. <span class="label label-obs">[OBS]</span>
          Symmetry as Evidence: the geometric program exhibits bilateral symmetry; the design field is divisible into mirrored quadrants without remainder. <span class="label label-obs">[OBS]</span>
        </p>
      </div>
      <div class="analysis-meta" style="margin-top: var(--space-8);">
        <p class="analysis-title">Pass 2 — artifact analysis (documentation available)</p>
      </div>
      <div class="analysis-text">
        <p>
          This is a Classic Mimbres Black-on-white bowl. Single-pigment program on a brilliant white slip routes to CHECK 2 of the tradition identification matrix <span class="label label-cons">[CONS]</span>;
          the bowl form, interior-dominant composition, and geometric design program are consistent with Classic Mimbres production standards <span class="label label-cons">[CONS — Brody 2004, Shafer 2003]</span>.
          Coil-and-scrape construction is the standard Mimbres method <span class="label label-cons">[CONS — Brody, Shafer]</span>,
          and the oblique striations confirm it here. <span class="label label-obs">[OBS]</span>
        </p>
        <p>
          The geometric program fills the full bowl interior as a central medallion composition. <span class="label label-obs">[OBS]</span>
          The positive-negative capacity of the design — readable simultaneously as dark-on-light or light-on-dark — is the specific technical achievement Brody identifies as the core formal accomplishment of Mimbres geometric work.
          <span class="label label-interp">[INTERP — Brody; Mimbres geometric only]</span>
          This is not a general formal virtue; it is a deliberately built structural property of this composition. <span class="label label-theory">[THEORY — iconographic program analysis, Brody/Schaafsma]</span>
        </p>
        <p>
          Kill hole is present at base, punched post-firing. <span class="label label-obs">[OBS]</span>
          Kill hole practice is a Mimbres burial marker that does not begin until the Late Three Circle phase — it is a Classic period indicator and confirms burial context. <span class="label label-cons">[CONS — Shafer, NAN Ranch ch. 8]</span>
        </p>
      </div>
    </div>

    <!-- RAP flags -->
    <div class="rap-section">
      <div class="rap-head">
        <p class="analysis-title">RAP Protocol flags</p>
        <p class="analysis-note">Every interpretive claim is anchored in observable evidence. The RAP Protocol requires a minimum of two independent observations to support an interpretive claim. Claims with fewer are labeled hypotheses.</p>
      </div>
      <div class="rap-flags">
        {rapFlags.map(flag => (
          <div class="rap-flag">
            <div class="rap-meta">
              <span class={`rap-confidence conf-${flag.confidence}`}>{flag.confidence}</span>
              <span class="rap-type">{flag.claim_type.replace(/_/g, ' ')}</span>
              <span class="rap-anchors">{flag.anchor_count} anchor{flag.anchor_count !== 1 ? 's' : ''}</span>
            </div>
            <p class="rap-claim">{flag.claim}</p>
            <p class="rap-gloss">{flag.gloss}</p>
          </div>
        ))}
      </div>
    </div>

    <!-- 27-principle fingerprint -->
    <div class="fingerprint-section">
      <div class="fingerprint-head">
        <p class="analysis-title">27-principle perceptual fingerprint</p>
        <p class="analysis-note">Scored 0–3 from Pass 1 observation alone. This vector is stored against the object record; it is the basis for future cross-corpus comparison. Scores of 0 are common — most principles are not active in any given object.</p>
        <div class="score-legend">
          <span class="score-swatch score-0">0 = not present</span>
          <span class="score-swatch score-1">1 = peripheral</span>
          <span class="score-swatch score-2">2 = operative</span>
          <span class="score-swatch score-3">3 = dominant</span>
        </div>
      </div>
      <div class="fingerprint-groups">
        <div class="fp-group">
          <p class="fp-group-label">Artifact-domain principles (ap_1–ap_15)</p>
          <div class="fp-grid">
            {artifactPrinciples.map(p => (
              <div class="fp-row">
                <span class="fp-code">{p.code}</span>
                <div class="fp-bar-wrap">
                  <div class={`fp-bar ${scoreColor(p.score)}`} style={`width: ${(p.score / 3) * 100}%`}></div>
                </div>
                <span class="fp-score">{p.score}</span>
                <span class="fp-name">{p.name}</span>
                <span class="fp-desc">{p.desc}</span>
              </div>
            ))}
          </div>
        </div>
        <div class="fp-group">
          <p class="fp-group-label">Universal Tier A principles (applicable subset)</p>
          <div class="fp-grid">
            {universalPrinciples.map(p => (
              <div class="fp-row">
                <span class="fp-code">{p.code}</span>
                <div class="fp-bar-wrap">
                  <div class={`fp-bar ${scoreColor(p.score)}`} style={`width: ${(p.score / 3) * 100}%`}></div>
                </div>
                <span class="fp-score">{p.score}</span>
                <span class="fp-name">{p.name}</span>
                <span class="fp-desc">{p.desc}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

  </div>
</section>

<style>
  section { background: var(--bg); border-bottom: 1px solid var(--border); }
  .section-head { margin-bottom: var(--space-12); }
  .section-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    margin-bottom: var(--space-3);
    max-width: none;
  }
  h2 { font-size: clamp(var(--text-2xl), 3vw, var(--text-4xl)); letter-spacing: -0.015em; margin-bottom: var(--space-4); }
  .section-sub { font-size: var(--text-base); color: var(--text-muted); line-height: 1.6; }

  /* Legend */
  .legend {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: var(--space-6) var(--space-8);
    margin-bottom: var(--space-12);
  }
  .legend-head {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-4);
    max-width: none;
  }
  .legend-items { display: flex; flex-direction: column; gap: var(--space-3); }
  .legend-item {
    display: flex;
    align-items: baseline;
    gap: var(--space-4);
    font-size: var(--text-sm);
    color: var(--text-muted);
  }
  .legend-item .label { flex-shrink: 0; }

  /* Analysis block */
  .analysis-block {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: var(--space-8);
    margin-bottom: var(--space-12);
  }
  .analysis-meta { margin-bottom: var(--space-6); }
  .analysis-title {
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    color: var(--text);
    font-weight: 600;
    max-width: none;
    margin-bottom: var(--space-2);
  }
  .analysis-note { font-size: var(--text-sm); color: var(--text-muted); max-width: 60ch; }
  .analysis-text { display: flex; flex-direction: column; gap: var(--space-4); }
  .analysis-text p { font-size: var(--text-base); line-height: 1.8; max-width: 80ch; }

  /* RAP flags */
  .rap-section {
    margin-bottom: var(--space-12);
  }
  .rap-head { margin-bottom: var(--space-6); }
  .rap-flags { display: flex; flex-direction: column; gap: var(--space-4); }
  .rap-flag {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: var(--space-6);
  }
  .rap-meta {
    display: flex;
    align-items: center;
    gap: var(--space-3);
    margin-bottom: var(--space-3);
    flex-wrap: wrap;
  }
  .rap-confidence {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    padding: 0.15em 0.6em;
    border-radius: 2px;
  }
  .conf-reading   { background: var(--cons-bg);   color: var(--cons);   }
  .conf-hypothesis { background: var(--theory-bg); color: var(--theory); }
  .conf-indeterminate { background: var(--bg-alt); color: var(--text-muted); }
  .rap-type {
    font-size: var(--text-xs);
    color: var(--text-muted);
    font-family: var(--font-mono);
    letter-spacing: 0.03em;
  }
  .rap-anchors {
    font-size: var(--text-xs);
    color: var(--text-muted);
    margin-left: auto;
    font-family: var(--font-mono);
  }
  .rap-claim {
    font-size: var(--text-base);
    color: var(--text);
    line-height: 1.6;
    margin-bottom: var(--space-3);
    max-width: 80ch;
  }
  .rap-gloss { font-size: var(--text-sm); color: var(--text-muted); max-width: 70ch; }

  /* Fingerprint */
  .fingerprint-section {}
  .fingerprint-head { margin-bottom: var(--space-8); }
  .score-legend {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
    margin-top: var(--space-4);
  }
  .score-swatch {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    padding: 0.2em 0.6em;
    border-radius: 2px;
  }
  .fingerprint-groups { display: flex; flex-direction: column; gap: var(--space-10); }
  .fp-group {
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: var(--space-6) var(--space-8);
  }
  .fp-group-label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: var(--space-6);
    max-width: none;
  }
  .fp-grid { display: flex; flex-direction: column; gap: var(--space-2); }
  .fp-row {
    display: grid;
    grid-template-columns: 48px 80px 20px 200px 1fr;
    gap: var(--space-4);
    align-items: center;
  }
  .fp-code {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--text-muted);
  }
  .fp-bar-wrap {
    height: 8px;
    background: var(--bg-alt);
    border-radius: 2px;
    overflow: hidden;
  }
  .fp-bar { height: 100%; border-radius: 2px; transition: width var(--ease); }
  .fp-score {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 700;
    color: var(--text);
    text-align: center;
  }
  .fp-name { font-size: var(--text-sm); color: var(--text); font-weight: 500; }
  .fp-desc { font-size: var(--text-xs); color: var(--text-muted); line-height: 1.5; }

  .score-0 { background: var(--bg-alt); color: var(--text-muted); }
  .score-1 { background: #c8a882; color: var(--text); }
  .score-2 { background: var(--accent-light); color: #fff; }
  .score-3 { background: var(--accent); color: #fff; }

  @media (max-width: 900px) {
    .fp-row { grid-template-columns: 40px 60px 16px 1fr; }
    .fp-name { font-size: var(--text-xs); }
    .fp-desc { display: none; }
  }
</style>
